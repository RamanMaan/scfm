---
import BaseHtml from "./BaseHtml.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const ogImage = "/og/default.png";
const ogImageAlt =
  "Steven Christopher — paper-bright monospace layout with a single focal frame.";
---

<BaseHtml
  title={title}
  description={description}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  bodyClass="brut"
>
  <slot />
</BaseHtml>
