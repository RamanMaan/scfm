---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  videos: CollectionEntry<"videos">[];
  channelUrl: string;
}

const { videos, channelUrl } = Astro.props;
const pad = (n: number) => String(n).padStart(2, "0");

const watchUrl = (video: CollectionEntry<"videos">): string => {
  if (video.data.youtubeUrl) return video.data.youtubeUrl;
  if (video.data.youtubeId) {
    return `https://www.youtube.com/watch?v=${video.data.youtubeId}`;
  }
  return channelUrl;
};

const thumbHi = (id: string) => `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
const thumbLo = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;

const THUMB_SIZES = "(min-width: 1080px) 33vw, (min-width: 720px) 50vw, 100vw";
const THUMB_WIDTHS = [320, 640, 1280];
---

<section class="br-section" id="video">
  <p class="br-eyebrow">[04] Catalogue / Visual</p>
  <h2 class="br-vid__title">VIDEOS &mdash; MOVING IMAGE</h2>

  {
    videos.length > 0 ? (
      <ul class="br-vid__list">
        {videos.map((video, index) => {
          const id = video.data.youtubeId;
          return (
            <li class="br-vid">
              <header class="br-vid__head">
                <span>VID-{pad(index + 1)}</span>
                <span>{video.data.title.toUpperCase()}</span>
              </header>
              <a
                class="br-vid__link"
                href={watchUrl(video)}
                target="_blank"
                rel="noopener"
                aria-label={`Watch ${video.data.title} on YouTube`}
              >
                {id ? (
                  <span class="br-vid__media" aria-hidden="true">
                    <Image
                      src={thumbHi(id)}
                      data-fallback={thumbLo(id)}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      width={1280}
                      height={720}
                      widths={THUMB_WIDTHS}
                      sizes={THUMB_SIZES}
                    />
                    <span class="br-vid__play">[ ▶ WATCH ON YOUTUBE ]</span>
                  </span>
                ) : (
                  <span class="br-vid__placeholder">
                    [ THUMBNAIL PENDING -- VIEW ON YOUTUBE &rarr; ]
                  </span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p>
        <a href={channelUrl}>
          &gt; FULL CHANNEL: YOUTUBE.COM/C/STEVENCHRISTOPHER
        </a>
      </p>
    )
  }
</section>

<script>
  const imgs = document.querySelectorAll<HTMLImageElement>(
    ".br-vid__media img[data-fallback]",
  );
  imgs.forEach((img) => {
    const handleError = () => {
      const fallback = img.dataset.fallback;
      if (!fallback || img.src === fallback) return;
      img.removeAttribute("srcset");
      img.src = fallback;
    };
    img.addEventListener("error", handleError, { once: true });
  });
</script>

<style>
  .br-vid__title {
    font-size: clamp(28px, 4vw, 48px);
    margin-bottom: 24px;
  }

  .br-vid__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
    gap: 24px;
  }

  .br-vid {
    border: var(--br-rule) solid var(--br-ink);
  }

  .br-vid__head {
    display: flex;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid var(--br-ink);
    font-size: 11px;
    letter-spacing: 0.1em;
    background: var(--br-ink);
    color: var(--br-bg);
  }

  .br-vid__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .br-vid__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--br-ink);
  }

  .br-vid__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
    transition: filter 200ms ease;
  }

  .br-vid__play {
    position: absolute;
    inset: auto 0 0 0;
    padding: 10px 12px;
    font-size: 11px;
    letter-spacing: 0.1em;
    background: var(--br-ink);
    color: var(--br-bg);
    border-top: 1px solid var(--br-ink);
    text-align: center;
  }

  .br-vid__link:hover .br-vid__media img,
  .br-vid__link:focus-visible .br-vid__media img {
    filter: grayscale(0) contrast(1);
  }

  .br-vid__link:focus-visible {
    outline: 2px solid var(--br-ink);
    outline-offset: 2px;
  }

  .br-vid__placeholder {
    display: flex;
    aspect-ratio: 16 / 9;
    align-items: center;
    justify-content: center;
    padding: 16px;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .br-vid__media img {
      transition: none;
    }
  }
</style>
