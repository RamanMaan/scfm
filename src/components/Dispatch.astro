---
const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const web3AccessKey = typeof accessKey === "string" ? accessKey : "";
---

<section class="br-section br-disp" id="contact">
  <p class="br-eyebrow">[02] Correspondence / Subscribe</p>
  <article class="br-card br-card--signal">
    <div class="br-signal">
      <div class="br-signal__copy">
        <p class="br-signal__kicker">Mailing list</p>
        <h3>GET IT FIRST.</h3>
        <p>
          Music before it hits the feeds. Show dates. Nothing promotional.
        </p>
      </div>
      <form class="br-form br-form--signal" data-w3f novalidate>
        <input type="hidden" name="access_key" value={web3AccessKey} />
        <input
          type="hidden"
          name="subject"
          value="Mailing list signup — stevenchristopher.fm"
        />
        <input
          type="hidden"
          name="from_name"
          value="Steven Christopher Site"
        />
        <input
          type="checkbox"
          name="botcheck"
          class="br-form__bot"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <label class="br-signal__email">
          <span>Email Address</span>
          <input
            type="email"
            name="email"
            autocomplete="email"
            inputmode="email"
            placeholder="you@domain.com"
            required
            maxlength="120"
          />
        </label>
        <button class="br-form__submit br-signal__submit" type="submit">
          Sign up
        </button>
        <p class="br-form__status" data-status role="status" aria-live="polite">
        </p>
      </form>
    </div>
  </article>
</section>

<script is:inline>
  (() => {
    const forms = document.querySelectorAll("[data-w3f]");
    if (!forms.length) return;

    const ENDPOINT = "https://api.web3forms.com/submit";

    const setStatus = (status, text, tone) => {
      if (!status) return;
      status.textContent = text;
      status.dataset.tone = tone || "";
    };

    forms.forEach((form) => {
      const status = form.querySelector("[data-status]");
      const submit = form.querySelector('button[type="submit"]');

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        const data = new FormData(form);
        if (data.get("botcheck")) return;

        const email = String(data.get("email") || "").trim();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          setStatus(status, "> INVALID ADDRESS. RETRY.", "error");
          return;
        }

        submit.disabled = true;
        setStatus(status, "> TRANSMITTING\u2026", "pending");

        try {
          const res = await fetch(ENDPOINT, {
            method: "POST",
            headers: { Accept: "application/json" },
            body: data,
          });
          const json = await res.json();
          if (json && json.success) {
            setStatus(status, "> RECEIVED. STAND BY.", "ok");
            form.reset();
          } else {
            setStatus(status, "> ERROR. RETRY.", "error");
          }
        } catch {
          setStatus(status, "> NO SIGNAL. RETRY.", "error");
        } finally {
          submit.disabled = false;
        }
      });
    });
  })();
</script>

<style>
  .br-form {
    display: grid;
    gap: 24px;
    border: var(--br-rule) solid var(--br-ink);
    padding: 20px;
    background: var(--br-bg);
  }

  .br-form__bot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .br-form__submit {
    appearance: none;
    border: var(--br-rule) solid var(--br-ink);
    background: var(--br-ink);
    color: var(--br-bg);
    font: inherit;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 14px 22px;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    transition:
      background-color 200ms ease,
      color 200ms ease,
      transform 120ms ease;
  }

  .br-form__submit:hover:not(:disabled),
  .br-form__submit:focus-visible:not(:disabled) {
    background: var(--br-bg);
    color: var(--br-ink);
  }

  .br-form__submit:active:not(:disabled) {
    transform: translateY(1px);
  }

  .br-form__submit:disabled {
    cursor: progress;
    opacity: 0.6;
  }

  .br-form__status {
    margin: 0;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--br-muted);
    min-height: 1em;
  }

  .br-form__status[data-tone="ok"] {
    color: var(--br-ink);
    font-weight: 700;
  }

  .br-form__status[data-tone="error"] {
    color: var(--br-accent);
    font-weight: 700;
  }

  .br-card {
    border: var(--br-rule) solid var(--br-ink);
    background: var(--br-bg);
  }

  .br-form input[type="email"],
  .br-form input[type="text"],
  .br-form textarea {
    appearance: none;
    border: 0;
    background: transparent;
    color: inherit;
    font: inherit;
    width: 100%;
  }

  .br-form input[type="email"]:focus,
  .br-form input[type="text"]:focus,
  .br-form textarea:focus {
    outline: none;
  }

  .br-card--signal {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px)
        0 0 / 18px 18px,
      var(--br-ink);
    color: var(--br-bg);
  }

  .br-signal {
    display: grid;
    gap: 20px;
    padding: 20px;
  }

  @media (min-width: 820px) {
    .br-signal {
      grid-template-columns: 0.9fr 1.1fr;
      align-items: stretch;
    }
  }

  .br-signal__copy {
    display: grid;
    align-content: space-between;
    min-height: 280px;
    border: 1px solid var(--br-bg);
    padding: 16px;
  }

  .br-signal__copy h3 {
    font-size: clamp(42px, 8vw, 112px);
    line-height: 0.82;
    letter-spacing: -0.08em;
  }

  .br-signal__copy p {
    margin: 0;
    max-width: 40ch;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .br-signal__kicker {
    font-size: 11px;
    color: #b8b8b8;
  }

  .br-form--signal {
    border-color: var(--br-bg);
    background: var(--br-ink);
    color: var(--br-bg);
    gap: 18px;
  }

  .br-signal__email {
    display: grid;
    gap: 10px;
    border: 1px solid var(--br-bg);
    padding: 12px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .br-signal__email input {
    min-height: 56px;
    border-top: 1px solid var(--br-bg);
    padding-top: 10px;
    font-size: clamp(20px, 5vw, 44px);
    letter-spacing: -0.05em;
    text-transform: none;
  }

  .br-signal__submit {
    justify-content: center;
    border-color: var(--br-bg);
    background: var(--br-bg);
    color: var(--br-ink);
  }

  .br-signal__submit:hover:not(:disabled),
  .br-signal__submit:focus-visible:not(:disabled) {
    background: var(--br-ink);
    color: var(--br-bg);
  }
</style>
