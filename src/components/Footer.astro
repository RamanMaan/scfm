---
import type { CollectionEntry } from "astro:content";
import { SOCIAL_ICON_PATH } from "../lib/social-icons";
import { orderedSocials, type SocialPlatform } from "../lib/socials";


interface Props {
  artist: CollectionEntry<"artist">;
  press: CollectionEntry<"press">[];
}

const { artist, press } = Astro.props;
const pad = (n: number) => String(n).padStart(2, "0");

const links = orderedSocials(artist.data.socials);
---

<footer class="br-section" id="press">
  {
    press.length > 0 && (
      <div class="br-press">
        <p class="br-eyebrow">[05] Press / Cited</p>
        <ol class="br-press__list">
          {press.map((quote, index) => (
            <li class="br-press__item">
              <sup>{pad(index + 1)}</sup>
              <p class="br-press__quote">&ldquo;{quote.data.quote}&rdquo;</p>
              <p class="br-press__source">
                &mdash;{" "}
                <a href={quote.data.sourceUrl}>
                  {quote.data.source.toUpperCase()}
                </a>
              </p>
            </li>
          ))}
        </ol>
      </div>
    )
  }

  <div class="br-end" id="connect">
    <nav class="br-connect" aria-label="Social links">
      <ul class="br-connect__icons">
        {
          links.map(({ platform, url, label }) => (
            <li>
              <a href={url} target="_blank" rel="noopener" aria-label={label}>
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d={SOCIAL_ICON_PATH[platform]} />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="br-end__colophon">
      <p>&copy; {new Date().getFullYear()} {artist.data.name.toUpperCase()}.</p>
    </div>
  </div>
</footer>
