---
import { Picture } from "astro:assets";
import heroImage from "../assets/HeroImage.jpg";

interface Props {
  name: string;
}

const { name } = Astro.props;
const segments = name.toUpperCase().split(" ");
---

<header class="br-hero" id="top">
  <h1 class="br-hero__title" aria-label={name}>
    {segments.map((segment) => <span class="br-hero__word">{segment}</span>)}
  </h1>

  <figure class="br-hero__figure" aria-label={`${name} — studio portrait`}>
    <Picture
      class="br-hero__still"
      src={heroImage}
      alt={`Portrait of ${name}`}
      widths={[640, 1080, 1600, 2400]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={78}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>
</header>

<style>
  .br-hero {
    border-bottom: var(--br-rule) solid var(--br-ink);
  }

  .br-hero__figure {
    margin: 0;
    border-top: var(--br-rule) solid var(--br-ink);
    background: var(--br-bg);
    overflow: hidden;
  }

  .br-hero__still {
    display: block;
    width: 100%;
    height: clamp(60vh, 78vw, 88vh);
    max-height: 880px;
    object-fit: cover;
  }

  .br-hero__title {
    display: block;
    padding: 8px 16px 20px;
    font-size: clamp(40px, 13vw, 200px);
    line-height: 0.85;
    letter-spacing: -0.03em;
    margin: 0;
    overflow: hidden;
  }

  .br-hero__word {
    display: block;
    white-space: nowrap;
  }

  .br-hero__word:nth-child(even) {
    text-align: right;
  }
</style>
