---
import type { CollectionEntry } from "astro:content";
import {
  SPOTIFY_EMBED_HEIGHT,
  getSpotifyEmbedUrl,
  spotifyOpenUrl,
} from "../lib/spotify";

interface Props {
  featured?: CollectionEntry<"releases">;
  rest: CollectionEntry<"releases">[];
}

const { featured, rest } = Astro.props;
const all = featured ? [featured, ...rest] : rest;
const pad = (n: number) => String(n).padStart(2, "0");
---

<section class="br-section" id="music">
  <p class="br-eyebrow">[03] Catalogue / Audio</p>
  <h2 class="br-rel__title">MUSIC</h2>

  {
    featured && (
      <article class="br-feat">
        <header class="br-feat__head">
          <span class="br-eyebrow">FEATURED SINGLE</span>
        </header>
        {featured.data.spotifyId ? (
          <iframe
            class="br-feat__embed"
            src={getSpotifyEmbedUrl({
              type: featured.data.spotifyType,
              id: featured.data.spotifyId,
              theme: 0,
            })}
            width="100%"
            height={SPOTIFY_EMBED_HEIGHT.full}
            loading="lazy"
            allowfullscreen
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            title={`Spotify player: ${featured.data.title}`}
          />
        ) : (
          null
        )}
      </article>
    )
  }

  <table class="br-table">
    <thead>
      <tr>
        <th scope="col">No.</th>
        <th scope="col">Title</th>
        <th scope="col">Type</th>
        <th scope="col">Links</th>
      </tr>
    </thead>
    <tbody>
      {
        all.map((release, index) => {
          const spotifyHref = release.data.spotifyId
            ? spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId)
            : null;
          const appleHref = release.data.appleMusicUrl ?? null;
          const hasLinks = spotifyHref || appleHref;

          return (
            <tr>
              <td class="br-table__num">{pad(index + 1)}</td>
              <td class="br-table__title">
                {release.data.title.toUpperCase()}
                {release.data.featuring.length > 0 && (
                  <span class="br-table__feat">
                    {" "}
                    / {release.data.featuring.join(" / ")}
                  </span>
                )}
              </td>
              <td>{release.data.type.toUpperCase()}</td>
              <td class="br-table__links">
                {hasLinks ? (
                  <>
                    {spotifyHref && <a href={spotifyHref}>SPOTIFY</a>}
                    {spotifyHref && appleHref && (
                      <span class="br-table__links-sep" aria-hidden="true">/</span>
                    )}
                    {appleHref && <a href={appleHref}>APPLE MUSIC</a>}
                  </>
                ) : (
                  "--"
                )}
              </td>
            </tr>
          );
        })
      }
    </tbody>
  </table>
</section>
