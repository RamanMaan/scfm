---
import { getCollection, getEntry } from "astro:content";
import Divider from "../variants/atelier/components/Divider.astro";
import Footer from "../variants/atelier/components/Footer.astro";
import Hero from "../variants/atelier/components/Hero.astro";
import Nav from "../variants/atelier/components/Nav.astro";
import ReleaseList from "../variants/atelier/components/ReleaseList.astro";
import VideoGrid from "../variants/atelier/components/VideoGrid.astro";
import Layout from "../variants/atelier/Layout.astro";

const artist = await getEntry("artist", "profile");
if (!artist) {
  throw new Error("Missing artist profile entry");
}

const releases = (await getCollection("releases")).sort(
  (a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf(),
);

const videos = (await getCollection("videos")).sort(
  (a, b) =>
    (b.data.releaseDate?.valueOf() ?? 0) - (a.data.releaseDate?.valueOf() ?? 0),
);
---

<Layout
  title={`${artist.data.name} - ${artist.data.tagline}`}
  description={artist.data.bio}
>
  <Nav name={artist.data.name} />
  <Hero name={artist.data.name} />
  <Divider />
  <ReleaseList releases={releases} />
  <Divider />
  <VideoGrid videos={videos} channelUrl={artist.data.socials.youtube} />
  <Divider />
  <Footer artist={artist} />
</Layout>
