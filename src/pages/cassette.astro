---
import { getCollection, getEntry } from "astro:content";
import Footer from "../variants/cassette/components/Footer.astro";
import Hero from "../variants/cassette/components/Hero.astro";
import Nav from "../variants/cassette/components/Nav.astro";
import ReleaseList from "../variants/cassette/components/ReleaseList.astro";
import VideoGrid from "../variants/cassette/components/VideoGrid.astro";
import Layout from "../variants/cassette/Layout.astro";

const artist = await getEntry("artist", "profile");
if (!artist) {
  throw new Error("Missing artist profile entry");
}

const RECENT_RELEASES_LIMIT = 5;

const releases = (await getCollection("releases"))
  .sort((a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf())
  .slice(0, RECENT_RELEASES_LIMIT);

const videos = (await getCollection("videos")).sort(
  (a, b) =>
    (b.data.releaseDate?.valueOf() ?? 0) - (a.data.releaseDate?.valueOf() ?? 0),
);
---

<Layout
  title={`${artist.data.name} — ${artist.data.tagline}`}
  description={artist.data.bio}
>
  <Nav name={artist.data.name} catalogNumber="SC-001" />
  <main class="cz-jcard">
    <Hero
      name={artist.data.name}
      tagline={artist.data.tagline}
      origin={artist.data.origin}
      basedIn={artist.data.basedIn}
      catalogNumber="SC-001"
    />
    <ReleaseList releases={releases} />
    <VideoGrid videos={videos} channelUrl={artist.data.socials.youtube} />
    <Footer artist={artist} />
  </main>
</Layout>
