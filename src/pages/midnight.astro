---
import { getCollection, getEntry } from "astro:content";
import Footer from "../variants/midnight/components/Footer.astro";
import Hero from "../variants/midnight/components/Hero.astro";
import ReleaseList from "../variants/midnight/components/ReleaseList.astro";
import VideoGrid from "../variants/midnight/components/VideoGrid.astro";
import Layout from "../variants/midnight/Layout.astro";

const artist = await getEntry("artist", "profile");
if (!artist) {
  throw new Error("Missing artist profile entry");
}

const releases = (await getCollection("releases")).sort(
  (a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf(),
);
const featured = releases.find((release) => release.data.isFeatured);
const rest = releases.filter((release) => release.id !== featured?.id);

const videos = (await getCollection("videos")).sort(
  (a, b) =>
    (b.data.releaseDate?.valueOf() ?? 0) - (a.data.releaseDate?.valueOf() ?? 0),
);

const press = (await getCollection("press")).sort(
  (a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0),
);
---

<Layout
  title={`${artist.data.name} - ${artist.data.tagline}`}
  description={artist.data.bio}
>
  <Hero
    name={artist.data.name}
    tagline={artist.data.tagline}
    basedIn={artist.data.basedIn}
    origin={artist.data.origin}
  />
  <ReleaseList featured={featured} rest={rest} />
  <VideoGrid videos={videos} channelUrl={artist.data.socials.youtube} />
  <Footer artist={artist} press={press} />
</Layout>
