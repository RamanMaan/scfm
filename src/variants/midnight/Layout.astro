---
import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="midnight"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    slot="head"
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
  />
  <slot />
</BaseHtml>

<script>
  // Scroll-reveal: add .is-visible to anything marked .mn-reveal once it
  // crosses ~15% into the viewport. Mobile-friendly (no hover dependency)
  // and inert under reduced-motion (the CSS already neutralises the transform).
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = document.querySelectorAll<HTMLElement>(".mn-reveal");

  if (reduced || typeof IntersectionObserver === "undefined") {
    targets.forEach((el) => el.classList.add("is-visible"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "0px 0px -15% 0px", threshold: 0.05 },
    );
    targets.forEach((el) => io.observe(el));
  }
</script>

<style is:global>
  .midnight {
    --mn-bg: #07080b;
    --mn-surface: #11131a;
    --mn-text: #e8e9ec;
    --mn-text-dim: rgba(232, 233, 236, 0.6);
    --mn-text-faint: rgba(232, 233, 236, 0.35);
    --mn-rule: rgba(232, 233, 236, 0.1);
    --mn-accent: #7a8b9c;
    --mn-serif: "Cormorant Garamond", "Cormorant", Georgia, serif;
    --mn-sans: "Inter", system-ui, sans-serif;

    /* Motion tokens — slow, intentional. Never springy. */
    --mn-ease: cubic-bezier(0.22, 0.61, 0.36, 1);
    --mn-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --mn-dur-fast: 280ms;
    --mn-dur-med: 600ms;
    --mn-dur-slow: 1100ms;

    background: var(--mn-bg);
    color: var(--mn-text);
    font-family: var(--mn-sans);
    font-weight: 300;
    line-height: 1.6;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
  }

  .midnight ::selection {
    background: var(--mn-accent);
    color: var(--mn-bg);
  }

  .midnight a {
    color: inherit;
    text-decoration: none;
    transition:
      color 0.3s ease,
      opacity 0.3s ease;
  }

  .midnight a:hover {
    color: var(--mn-accent);
  }

  .midnight h1,
  .midnight h2,
  .midnight h3 {
    font-family: var(--mn-serif);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .midnight :focus-visible {
    outline: 1px solid var(--mn-accent);
    outline-offset: 4px;
  }

  .midnight .mn-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
  }

  .midnight .mn-section {
    padding-block: clamp(64px, 10vw, 128px);
    border-top: 1px solid var(--mn-rule);
  }

  .midnight .mn-eyebrow {
    font-family: var(--mn-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mn-text-faint);
    margin-bottom: 24px;
  }

  .midnight .mn-section-title {
    font-size: clamp(32px, 5vw, 56px);
    line-height: 1.05;
    margin-bottom: 48px;
  }

  .midnight iframe {
    border: 0;
    border-radius: 12px;
    background: var(--mn-surface);
  }

  /* Motion: keyframes, reveal utility, reduced-motion guard. */

  @keyframes mn-fade-up {
    from {
      opacity: 0;
      transform: translate3d(0, 16px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes mn-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes mn-ken-burns {
    0% {
      transform: scale(1) translate3d(0, 0, 0);
    }
    50% {
      transform: scale(1.06) translate3d(-1.5%, -1%, 0);
    }
    100% {
      transform: scale(1) translate3d(0, 0, 0);
    }
  }

  @keyframes mn-breathe {
    0%,
    100% {
      opacity: 0.35;
      transform: translate3d(0, 0, 0);
    }
    50% {
      opacity: 0.9;
      transform: translate3d(0, 6px, 0);
    }
  }

  .midnight .mn-reveal {
    opacity: 0;
    transform: translate3d(0, 20px, 0);
    transition:
      opacity var(--mn-dur-slow) var(--mn-ease-out)
        calc(var(--mn-i, 0) * 90ms),
      transform var(--mn-dur-slow) var(--mn-ease-out)
        calc(var(--mn-i, 0) * 90ms);
    will-change: opacity, transform;
  }

  .midnight .mn-reveal.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .midnight,
    .midnight *,
    .midnight *::before,
    .midnight *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
    .midnight .mn-reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>
