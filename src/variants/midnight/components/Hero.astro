---
interface Props {
  name: string;
  tagline: string;
  basedIn: string;
  origin: string;
}

const { name, tagline, basedIn, origin } = Astro.props;
---

<header class="mn-hero">
  <div class="mn-hero__photo" aria-hidden="true"></div>
  <div class="mn-hero__inner mn-shell">
    <p class="mn-eyebrow mn-hero__eyebrow">{origin} &mdash; {basedIn}</p>
    <h1 class="mn-hero__title">{name}</h1>
    <p class="mn-hero__tagline">{tagline}</p>
  </div>
  <a class="mn-hero__scroll" href="#music" aria-label="Skip to music">
    <span class="mn-hero__scroll-label">scroll</span>
    <span class="mn-hero__scroll-line" aria-hidden="true"></span>
  </a>
</header>

<style>
  .mn-hero {
    position: relative;
    min-height: 88dvh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .mn-hero__photo {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(
        ellipse 80% 60% at 70% 30%,
        rgba(170, 190, 210, 0.14),
        transparent 60%
      ),
      radial-gradient(
        ellipse 60% 50% at 20% 80%,
        rgba(30, 42, 58, 0.55),
        transparent 65%
      ),
      linear-gradient(180deg, #04050a 0%, #07080b 60%, #0c0f15 100%);
    transform-origin: 60% 40%;
    will-change: transform;
  }

  .mn-hero__photo::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        transparent 50%,
        rgba(7, 8, 11, 0.9) 100%
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.012) 0px,
        rgba(255, 255, 255, 0.012) 1px,
        transparent 1px,
        transparent 3px
      );
  }

  @media (prefers-reduced-motion: no-preference) {
    .mn-hero__photo {
      animation: mn-ken-burns 60s var(--mn-ease) infinite;
    }
  }

  .mn-hero__inner {
    width: 100%;
    padding-bottom: clamp(80px, 14vh, 144px);
    padding-top: clamp(120px, 18vh, 200px);
  }

  .mn-hero__eyebrow {
    margin-bottom: 24px;
  }

  .mn-hero__title {
    font-size: clamp(56px, 14vw, 200px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin-bottom: 28px;
    font-style: italic;
    font-weight: 400;
  }

  .mn-hero__tagline {
    font-family: var(--mn-sans);
    font-size: clamp(15px, 1.4vw, 18px);
    font-weight: 300;
    color: var(--mn-text-dim);
    max-width: 38ch;
    margin: 0;
  }

  /* Staggered entrance on first paint. */
  @media (prefers-reduced-motion: no-preference) {
    .mn-hero__eyebrow,
    .mn-hero__title,
    .mn-hero__tagline {
      opacity: 0;
      animation: mn-fade-up var(--mn-dur-slow) var(--mn-ease-out) forwards;
    }
    .mn-hero__eyebrow {
      animation-delay: 120ms;
    }
    .mn-hero__title {
      animation-delay: 260ms;
    }
    .mn-hero__tagline {
      animation-delay: 480ms;
    }
  }

  .mn-hero__scroll {
    position: absolute;
    bottom: clamp(20px, 4vh, 36px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 12px 20px;
    min-height: 56px;
    color: var(--mn-text-faint);
    text-decoration: none;
  }

  .mn-hero__scroll-label {
    font-family: var(--mn-sans);
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
  }

  .mn-hero__scroll-line {
    display: block;
    width: 1px;
    height: 36px;
    background: linear-gradient(
      180deg,
      transparent,
      var(--mn-text-faint) 30%,
      var(--mn-text-faint) 70%,
      transparent
    );
  }

  @media (prefers-reduced-motion: no-preference) {
    .mn-hero__scroll-line {
      animation: mn-breathe 3.6s var(--mn-ease) infinite;
    }
  }

  .mn-hero__scroll:hover,
  .mn-hero__scroll:focus-visible,
  .mn-hero__scroll:active {
    color: var(--mn-text-dim);
  }

  @media (min-width: 720px) {
    .mn-hero__scroll {
      left: auto;
      right: clamp(20px, 5vw, 56px);
      transform: none;
    }
  }
</style>
