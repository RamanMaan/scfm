---
import type { CollectionEntry } from "astro:content";
import { orderedSocials } from "../../../lib/socials";

interface Props {
  artist: CollectionEntry<"artist">;
  press: CollectionEntry<"press">[];
}

const { artist, press } = Astro.props;
const socials = orderedSocials(artist.data.socials);
---

<footer class="mn-section mn-shell" id="footer">
  {
    press.length > 0 && (
      <div class="mn-press">
        <p class="mn-eyebrow mn-reveal">Press</p>
        <ul class="mn-press__list">
          {press.map((quote, idx) => (
            <li class="mn-press__item mn-reveal" style={`--mn-i: ${idx + 1}`}>
              <blockquote class="mn-press__quote">
                &ldquo;{quote.data.quote}&rdquo;
              </blockquote>
              <a class="mn-press__source" href={quote.data.sourceUrl}>
                &mdash; {quote.data.source}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  <div class="mn-footer__inner mn-reveal">
    <div>
      <p class="mn-eyebrow">Connect</p>
      <ul class="mn-socials">
        {
          socials.map(({ url, label }) => (
            <li>
              <a class="mn-social" href={url} target="_blank" rel="noopener">
                <span class="mn-social__label">{label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <p class="mn-colophon">
      &copy; {new Date().getFullYear()}
      {artist.data.name}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .mn-press {
    margin-bottom: 80px;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--mn-rule);
  }

  @media (min-width: 800px) {
    .mn-press {
      margin-bottom: 96px;
      padding-bottom: 96px;
    }
  }

  .mn-press__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 48px;
  }

  @media (min-width: 800px) {
    .mn-press__list {
      grid-template-columns: 1fr 1fr;
      gap: 64px;
    }
  }

  .mn-press__quote {
    font-family: var(--mn-serif);
    font-style: italic;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.3;
    margin: 0 0 16px;
    color: var(--mn-text);
  }

  .mn-press__source {
    display: inline-block;
    padding: 8px 0;
    min-height: 44px;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mn-text-faint);
    transition: color var(--mn-dur-fast) var(--mn-ease);
  }

  .mn-press__source:focus-visible,
  .mn-press__source:active {
    color: var(--mn-accent);
  }

  @media (hover: hover) {
    .mn-press__source:hover {
      color: var(--mn-accent);
    }
  }

  .mn-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: flex-start;
  }

  @media (min-width: 800px) {
    .mn-footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .mn-socials {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 28px;
  }

  /* Social link: animated underline that grows from the left on tap/hover/focus. */
  .mn-social {
    position: relative;
    display: inline-block;
    padding: 8px 0;
    min-height: 44px;
    font-family: var(--mn-serif);
    font-style: italic;
    font-size: 24px;
    line-height: 1.4;
    color: var(--mn-text);
  }

  .mn-social__label {
    position: relative;
    display: inline-block;
  }

  .mn-social__label::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 1px;
    background: var(--mn-accent);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform var(--mn-dur-med) var(--mn-ease-out);
  }

  .mn-social:focus-visible .mn-social__label::after,
  .mn-social:active .mn-social__label::after {
    transform: scaleX(1);
  }

  @media (hover: hover) {
    .mn-social:hover .mn-social__label::after {
      transform: scaleX(1);
    }
  }

  .mn-colophon {
    font-size: 12px;
    color: var(--mn-text-faint);
    letter-spacing: 0.08em;
    margin: 0;
  }
</style>
