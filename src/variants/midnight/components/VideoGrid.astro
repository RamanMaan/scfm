---
import type { CollectionEntry } from "astro:content";
import { youtubeEmbedUrl } from "../../../lib/socials";

interface Props {
  videos: CollectionEntry<"videos">[];
  channelUrl: string;
}

const { videos, channelUrl } = Astro.props;
---

<section class="mn-section mn-shell" id="videos">
  <p class="mn-eyebrow mn-reveal">Visuals</p>
  <h2 class="mn-section-title mn-reveal" style="--mn-i: 1">
    Music <em>videos</em>
  </h2>

  {
    videos.length > 0 ? (
      <ul class="mn-videos">
        {videos.map((video, idx) => (
          <li class="mn-video mn-reveal" style={`--mn-i: ${idx + 1}`}>
            {video.data.youtubeId ? (
              <div class="mn-video__frame">
                <iframe
                  src={youtubeEmbedUrl(video.data.youtubeId)}
                  title={video.data.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  loading="lazy"
                  allowfullscreen
                />
              </div>
            ) : (
              <a
                class="mn-video__placeholder"
                href={video.data.youtubeUrl ?? channelUrl}
                target="_blank"
                rel="noopener"
              >
                <span class="mn-video__play" aria-hidden="true">
                  &#9658;
                </span>
                <span class="mn-video__placeholder-label">
                  Watch on YouTube
                </span>
              </a>
            )}
            <p class="mn-video__title">{video.data.title}</p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mn-video__empty mn-reveal" style="--mn-i: 1">
        <a href={channelUrl}>Visit the YouTube channel &rarr;</a>
      </p>
    )
  }
</section>

<style>
  .mn-videos {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 720px) {
    .mn-videos {
      grid-template-columns: repeat(auto-fill, minmax(min(100%, 360px), 1fr));
      gap: 48px;
    }
  }

  .mn-video__frame {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--mn-surface);
    border-radius: 12px;
    overflow: hidden;
    transition:
      transform var(--mn-dur-med) var(--mn-ease-out),
      box-shadow var(--mn-dur-med) var(--mn-ease-out);
  }

  .mn-video__frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (hover: hover) {
    .mn-video:hover .mn-video__frame {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px -16px rgba(0, 0, 0, 0.65);
    }
  }

  .mn-video__placeholder {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 9;
    background: var(--mn-surface);
    border: 1px solid var(--mn-rule);
    border-radius: 12px;
    color: var(--mn-text-dim);
    font-size: 14px;
    letter-spacing: 0.04em;
    transition:
      color var(--mn-dur-fast) var(--mn-ease),
      border-color var(--mn-dur-fast) var(--mn-ease),
      transform var(--mn-dur-med) var(--mn-ease-out);
    min-height: 56px;
  }

  .mn-video__play {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 999px;
    border: 1px solid var(--mn-text-faint);
    font-size: 14px;
    color: var(--mn-text);
    transition:
      border-color var(--mn-dur-fast) var(--mn-ease),
      background-color var(--mn-dur-fast) var(--mn-ease);
  }

  .mn-video__placeholder-label {
    font-family: var(--mn-sans);
    font-size: 12px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .mn-video__placeholder:focus-visible,
  .mn-video__placeholder:active {
    color: var(--mn-accent);
    border-color: var(--mn-accent);
  }

  .mn-video__placeholder:focus-visible .mn-video__play,
  .mn-video__placeholder:active .mn-video__play {
    border-color: var(--mn-accent);
    background-color: rgba(122, 139, 156, 0.08);
  }

  @media (hover: hover) {
    .mn-video__placeholder:hover {
      color: var(--mn-accent);
      border-color: var(--mn-accent);
      transform: translateY(-3px);
    }
    .mn-video__placeholder:hover .mn-video__play {
      border-color: var(--mn-accent);
      background-color: rgba(122, 139, 156, 0.08);
    }
  }

  .mn-video__title {
    font-family: var(--mn-serif);
    font-style: italic;
    font-size: 22px;
    margin: 20px 0 0;
    color: var(--mn-text);
  }

  .mn-video__empty {
    color: var(--mn-text-dim);
  }
</style>
