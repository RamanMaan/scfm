---
import type { CollectionEntry } from "astro:content";
import {
  SPOTIFY_EMBED_HEIGHT,
  getSpotifyEmbedUrl,
  spotifyOpenUrl,
} from "../../../lib/spotify";

interface Props {
  featured?: CollectionEntry<"releases">;
  rest: CollectionEntry<"releases">[];
}

const { featured, rest } = Astro.props;

const primaryLink = (release: CollectionEntry<"releases">): string | null => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? null;
};

const releaseTypeLabel = (
  release: CollectionEntry<"releases">,
): string => release.data.type;
---

<section class="mn-section mn-shell" id="music">
  <p class="mn-eyebrow mn-reveal">Music</p>
  <h2 class="mn-section-title mn-reveal" style="--mn-i: 1">
    Latest <em>releases</em>
  </h2>

  {
    featured && (
      <article class="mn-featured mn-reveal" style="--mn-i: 2">
        <div class="mn-featured__meta">
          <p class="mn-eyebrow">Featured</p>
          <h3 class="mn-featured__title">{featured.data.title}</h3>
          {featured.data.featuring.length > 0 && (
            <p class="mn-featured__feat">
              with {featured.data.featuring.join(", ")}
            </p>
          )}
          {featured.data.description && (
            <p class="mn-featured__desc">{featured.data.description}</p>
          )}
        </div>
        <div class="mn-featured__player">
          {featured.data.spotifyId ? (
            <iframe
              src={getSpotifyEmbedUrl({
                type: featured.data.spotifyType,
                id: featured.data.spotifyId,
              })}
              width="100%"
              height={SPOTIFY_EMBED_HEIGHT.full}
              loading="lazy"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              title={`Spotify player: ${featured.data.title}`}
            />
          ) : (
            <a
              class="mn-featured__placeholder"
              href={featured.data.appleMusicUrl ?? "#"}
              target={featured.data.appleMusicUrl ? "_blank" : undefined}
              rel={featured.data.appleMusicUrl ? "noopener" : undefined}
            >
              <span class="mn-eyebrow">Listen</span>
              <span class="mn-featured__placeholder-cta">
                {featured.data.appleMusicUrl
                  ? "Apple Music \u2192"
                  : "Coming soon"}
              </span>
            </a>
          )}
        </div>
      </article>
    )
  }

  {
    rest.length > 0 && (
      <ol class="mn-discog">
        {rest.map((release, idx) => {
          const href = primaryLink(release);
          const RowTag = href ? "a" : "div";
          const rowAttrs = href
            ? { href, target: "_blank", rel: "noopener" }
            : {};
          return (
            <li
              class="mn-discog__item mn-reveal"
              style={`--mn-i: ${idx + 1}`}
            >
              <RowTag
                class:list={["mn-discog__row", !href && "mn-discog__row--static"]}
                {...rowAttrs}
              >
                <span class="mn-discog__title">
                  {release.data.title}
                  {release.data.featuring.length > 0 && (
                    <span class="mn-discog__feat">
                      {" "}
                      with {release.data.featuring.join(", ")}
                    </span>
                  )}
                </span>
                <span class="mn-discog__type">{releaseTypeLabel(release)}</span>
                {href && (
                  <span class="mn-discog__arrow" aria-hidden="true">
                    &rarr;
                  </span>
                )}
              </RowTag>
            </li>
          );
        })}
      </ol>
    )
  }
</section>

<style>
  .mn-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 80px;
    padding-bottom: 80px;
    border-bottom: 1px solid var(--mn-rule);
  }

  @media (min-width: 900px) {
    .mn-featured {
      grid-template-columns: 1fr 1.2fr;
      gap: 80px;
      align-items: center;
      margin-bottom: 96px;
      padding-bottom: 96px;
    }
  }

  .mn-featured__title {
    font-size: clamp(40px, 8vw, 64px);
    line-height: 1;
    font-style: italic;
    margin-block: 16px 16px;
  }

  .mn-featured__feat {
    font-family: var(--mn-serif);
    font-style: italic;
    color: var(--mn-text-dim);
    font-size: 18px;
    margin: 0 0 24px;
  }

  .mn-featured__desc {
    max-width: 44ch;
    color: var(--mn-text-dim);
    margin: 0;
  }

  .mn-featured__player {
    position: relative;
  }

  /* Subtle vignette glow behind the embed — pulls focus to the player. */
  .mn-featured__player::before {
    content: "";
    position: absolute;
    inset: -24px;
    z-index: -1;
    background: radial-gradient(
      ellipse at center,
      rgba(122, 139, 156, 0.18),
      transparent 70%
    );
    opacity: 0;
    transition: opacity var(--mn-dur-med) var(--mn-ease);
  }

  .mn-featured.is-visible .mn-featured__player::before {
    opacity: 1;
  }

  .mn-featured__placeholder {
    display: flex;
    flex-direction: column;
    gap: 16px;
    justify-content: center;
    align-items: flex-start;
    min-height: 220px;
    padding: 32px;
    background: var(--mn-surface);
    border: 1px solid var(--mn-rule);
    border-radius: 12px;
    color: var(--mn-text-dim);
    transition:
      border-color var(--mn-dur-med) var(--mn-ease),
      transform var(--mn-dur-med) var(--mn-ease);
  }

  .mn-featured__placeholder-cta {
    font-family: var(--mn-serif);
    font-style: italic;
    font-size: 24px;
    color: var(--mn-text);
  }

  @media (hover: hover) {
    .mn-featured__placeholder:hover {
      border-color: var(--mn-accent);
      transform: translateY(-2px);
    }
  }

  .mn-featured__placeholder:focus-visible,
  .mn-featured__placeholder:active {
    border-color: var(--mn-accent);
  }

  .mn-discog {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mn-discog__item {
    border-bottom: 1px solid var(--mn-rule);
  }

  .mn-discog__item:first-child {
    border-top: 1px solid var(--mn-rule);
  }

  /* Whole row is the tap target — Spotify primary, Apple Music fallback. */
  .mn-discog__row {
    display: grid;
    grid-template-columns: 1fr auto 24px;
    gap: 16px 24px;
    align-items: baseline;
    padding: 22px 4px;
    min-height: 56px;
    color: var(--mn-text);
    text-decoration: none;
    transition: background-color var(--mn-dur-fast) var(--mn-ease);
  }

  .mn-discog__row--static {
    cursor: default;
  }

  .mn-discog__title {
    font-family: var(--mn-serif);
    font-size: clamp(22px, 5.4vw, 32px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    transition: transform var(--mn-dur-med) var(--mn-ease-out);
  }

  .mn-discog__feat {
    display: inline-block;
    margin-left: 8px;
    font-size: 14px;
    font-style: normal;
    color: var(--mn-text-dim);
  }

  .mn-discog__type {
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mn-text-faint);
  }

  .mn-discog__arrow {
    justify-self: end;
    color: var(--mn-text-faint);
    transition:
      transform var(--mn-dur-med) var(--mn-ease-out),
      color var(--mn-dur-fast) var(--mn-ease);
  }

  /* Touch & focus states — always available, not hover-gated. */
  .mn-discog__row:focus-visible,
  .mn-discog__row:active {
    background-color: rgba(232, 233, 236, 0.03);
  }

  .mn-discog__row:focus-visible .mn-discog__arrow,
  .mn-discog__row:active .mn-discog__arrow {
    color: var(--mn-accent);
    transform: translateX(6px);
  }

  /* Hover-only enhancements — touch already has the above. */
  @media (hover: hover) {
    .mn-discog__row:hover {
      background-color: rgba(232, 233, 236, 0.03);
    }
    .mn-discog__row:hover .mn-discog__title {
      transform: translateX(4px);
    }
    .mn-discog__row:hover .mn-discog__arrow {
      color: var(--mn-accent);
      transform: translateX(6px);
    }
  }

  @media (max-width: 640px) {
    .mn-discog__row {
      grid-template-columns: 1fr 24px;
      grid-template-rows: auto auto;
      row-gap: 6px;
      padding: 20px 0;
    }
    .mn-discog__title {
      grid-column: 1;
      grid-row: 1;
    }
    .mn-discog__arrow {
      grid-column: 2;
      grid-row: 1;
      align-self: center;
    }
    .mn-discog__type {
      grid-column: 1;
      grid-row: 2;
    }
  }
</style>
