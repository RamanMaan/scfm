---
import "@fontsource-variable/inter-tight/wght.css";
import "@fontsource/courier-prime/400.css";
import "@fontsource/courier-prime/700.css";
import "@fontsource/reenie-beanie/400.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="cz"
>
  <slot />
</BaseHtml>

<style is:global>
  .cz {
    /* Stock + tape body */
    --cz-stock: #efe7d2;          /* cream cardboard */
    --cz-stock-2: #e6dcc0;        /* darker grain */
    --cz-shell: #d9cca6;          /* faint inner panel */
    --cz-tape: #2a2118;           /* tape body (warm near-black) */
    --cz-tape-2: #3a2f22;
    --cz-window: #5a4a36;         /* exposed reel window */

    /* Ink */
    --cz-ink: #16110b;            /* printed text */
    --cz-ink-soft: #4a3d2c;
    --cz-rule: rgba(22, 17, 11, 0.18);
    --cz-rule-soft: rgba(22, 17, 11, 0.08);

    /* Hand-marker accent — sharpie red, committed */
    --cz-marker: #c4302b;
    --cz-marker-ink: #a52822;     /* slightly darker for shadow */

    /* Registration plates (poorly aligned print) */
    --cz-reg-cyan: rgba(72, 132, 156, 0.32);
    --cz-reg-magenta: rgba(196, 48, 43, 0.22);

    /* Type stacks */
    --cz-mono:
      "Courier Prime", "Courier New", ui-monospace, SFMono-Regular,
      Menlo, monospace;
    --cz-hand:
      "Reenie Beanie", "Bradley Hand", "Lucida Handwriting", cursive;
    --cz-sans:
      "Inter Tight Variable", "Inter Tight", system-ui, -apple-system,
      "Segoe UI", "Helvetica Neue", sans-serif;

    --cz-ease: cubic-bezier(0.22, 0.61, 0.36, 1);

    background:
      /* warm vignette */
      radial-gradient(
        140% 90% at 50% 0%,
        rgba(255, 240, 200, 0.5) 0%,
        rgba(0, 0, 0, 0) 60%
      ),
      /* paper grain */
      repeating-linear-gradient(
        92deg,
        rgba(22, 17, 11, 0.012) 0 1px,
        transparent 1px 3px
      ),
      var(--cz-stock);
    color: var(--cz-ink);
    font-family: var(--cz-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0.005em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    min-height: 100dvh;
  }

  .cz::before {
    /* paper noise — extremely subtle SVG fractal */
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0.22;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.09 0 0 0 0 0.07 0 0 0 0 0.04 0 0 0 0.55 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }

  .cz ::selection {
    background: var(--cz-marker);
    color: var(--cz-stock);
  }

  .cz a {
    color: inherit;
    text-decoration: none;
    transition: color 240ms var(--cz-ease);
  }

  .cz a:hover {
    color: var(--cz-marker);
  }

  .cz :focus-visible {
    outline: 2px solid var(--cz-marker);
    outline-offset: 3px;
  }

  .cz h1,
  .cz h2,
  .cz h3 {
    margin: 0;
  }

  /* Reused micro-typography */
  .cz .cz-mono {
    font-family: var(--cz-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cz-ink-soft);
    font-variant-numeric: tabular-nums;
  }

  .cz .cz-hand {
    font-family: var(--cz-hand);
    color: var(--cz-marker);
    /* slight off-axis to feel handwritten */
    transform: rotate(-2deg);
    display: inline-block;
    text-shadow: 0 0 1px rgba(196, 48, 43, 0.25);
  }

  /* J-card container: the whole page lives inside a folded cassette insert. */
  .cz-jcard {
    position: relative;
    max-width: 880px;
    margin: 0 auto;
    padding: clamp(14px, 4vw, 32px) clamp(10px, 3vw, 24px)
      clamp(40px, 6vw, 80px);
  }

  /* The "deckle edge" — uneven paper edge along left/right of the J-card */
  .cz-panel {
    position: relative;
    background: var(--cz-stock);
    background-image:
      radial-gradient(
        100% 60% at 50% -20%,
        rgba(22, 17, 11, 0.05) 0%,
        rgba(0, 0, 0, 0) 60%
      ),
      repeating-linear-gradient(
        88deg,
        rgba(22, 17, 11, 0.018) 0 1px,
        transparent 1px 4px
      );
    border: 1px solid var(--cz-rule);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 22px 36px -22px rgba(22, 17, 11, 0.35),
      0 2px 0 rgba(22, 17, 11, 0.08);
    padding: clamp(16px, 4vw, 28px);
  }

  .cz-panel + .cz-panel {
    margin-top: clamp(18px, 3vw, 28px);
  }

  /* Section header rhythm: typewriter-style runner head */
  .cz-runner {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    padding-bottom: 14px;
    border-bottom: 1px dashed var(--cz-rule);
    margin-bottom: clamp(14px, 2vw, 22px);
  }

  .cz-runner__title {
    font-family: var(--cz-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--cz-ink);
  }

  .cz-runner__meta {
    font-family: var(--cz-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cz-ink-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .cz,
    .cz *,
    .cz *::before,
    .cz *::after {
      transition-duration: 0.001ms !important;
      animation: none !important;
    }
  }
</style>
