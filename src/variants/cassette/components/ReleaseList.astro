---
import type { CollectionEntry } from "astro:content";
import { formatShortDate, formatYear } from "../../../lib/formatDate";
import {
  SPOTIFY_EMBED_HEIGHT,
  getSpotifyEmbedUrl,
  spotifyOpenUrl,
} from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

// Total runtime would normally come from track data; we fabricate a believable
// "C-XX" tape length from the count of releases so the J-card reads as a real
// physical artifact instead of a CMS dump. 5 tracks ≈ 24 min ≈ C-30.
const tapeLengthMinutes = Math.max(30, releases.length * 6);

// Split chronologically: newest tracks lead Side A, older ones to Side B.
const half = Math.ceil(releases.length / 2);
const sideA = releases.slice(0, half);
const sideB = releases.slice(half);

const SIDES = [
  { key: "a", label: "Side A", title: "Side A", entries: sideA },
  { key: "b", label: "Side B", title: "Side B", entries: sideB },
] as const;

const primaryHref = (
  release: CollectionEntry<"releases">,
): string | undefined => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? undefined;
};

const formatLabel = (release: CollectionEntry<"releases">): string => {
  switch (release.data.type) {
    case "single":
      return "Single";
    case "ep":
      return "EP";
    case "album":
      return "LP";
  }
};
---

<section class="cz-section" aria-label="Tracklist">
  <div class="cz-tracklist cz-panel">
    <header class="cz-runner">
      <span class="cz-runner__title">Tracklist</span>
      <span class="cz-runner__meta">
        {releases.length.toString().padStart(2, "0")} cuts &middot; C-{tapeLengthMinutes}
      </span>
    </header>

    <div class="cz-tracklist__sides">
      {
        SIDES.map((side) => (
          <article
            class="cz-side"
            id={side.key === "a" ? "side-a" : "side-b"}
            data-side={side.key}
          >
            <header class="cz-side__head">
              <span class="cz-hand cz-side__label">{side.label}</span>
              <span class="cz-mono cz-side__rule" aria-hidden="true">
                ────────
              </span>
              <span class="cz-mono cz-side__count">
                {String(side.entries.length).padStart(2, "0")} tracks
              </span>
            </header>

            <ol class="cz-side__list" start={side.key === "a" ? 1 : sideA.length + 1}>
              {side.entries.map((release, idx) => {
                const href = primaryHref(release);
                const globalIdx =
                  (side.key === "a" ? idx : sideA.length + idx) + 1;
                const num = String(globalIdx).padStart(2, "0");
                const RowTag = href ? "a" : "div";
                const embedSrc = release.data.spotifyId
                  ? getSpotifyEmbedUrl({
                      type: release.data.spotifyType,
                      id: release.data.spotifyId,
                      theme: 1,
                    })
                  : null;

                return (
                  <li class="cz-track">
                    <RowTag
                      class:list={[
                        "cz-track__row",
                        !href && "cz-track__row--static",
                      ]}
                      {...(href
                        ? { href, target: "_blank", rel: "noopener" }
                        : {})}
                    >
                      <span class="cz-mono cz-track__num">{num}</span>
                      <span class="cz-track__body">
                        <span class="cz-track__title">
                          {release.data.title}
                          {release.data.featuring.length > 0 && (
                            <span class="cz-track__feat">
                              {" "}feat. {release.data.featuring.join(", ")}
                            </span>
                          )}
                        </span>
                        <span class="cz-track__meta">
                          <span class="cz-mono">
                            {formatLabel(release)}
                          </span>
                          <span class="cz-mono">·</span>
                          <span class="cz-mono">
                            {formatShortDate(release.data.releaseDate)}
                          </span>
                          {release.data.appleMusicUrl && (
                            <>
                              <span class="cz-mono">·</span>
                              <a
                                class="cz-mono cz-track__alt"
                                href={release.data.appleMusicUrl}
                                target="_blank"
                                rel="noopener"
                              >
                                Apple Music
                              </a>
                            </>
                          )}
                        </span>
                      </span>
                      <span class="cz-track__year cz-hand" aria-hidden="true">
                        '{formatYear(release.data.releaseDate).slice(-2)}
                      </span>
                    </RowTag>

                    {embedSrc && (
                      <details class="cz-track__player">
                        <summary class="cz-track__playbtn">
                          <span class="cz-track__playbtn-icon" aria-hidden="true">
                            ▸
                          </span>
                          <span class="cz-mono">Cue track</span>
                        </summary>
                        <div class="cz-track__embed">
                          <iframe
                            src={embedSrc}
                            width="100%"
                            height={SPOTIFY_EMBED_HEIGHT.compact}
                            frameborder="0"
                            loading="lazy"
                            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                            title={`Spotify player — ${release.data.title}`}
                          />
                        </div>
                      </details>
                    )}
                  </li>
                );
              })}
            </ol>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .cz-section {
    margin: 0 auto;
    max-width: 880px;
    padding: 0 clamp(10px, 3vw, 24px);
  }

  .cz-tracklist__sides {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 28px);
  }

  @media (min-width: 720px) {
    .cz-tracklist__sides {
      grid-template-columns: 1fr 1fr;
      gap: clamp(24px, 4vw, 36px);
    }
  }

  .cz-side {
    position: relative;
  }

  .cz-side + .cz-side {
    padding-top: clamp(16px, 2vw, 20px);
    border-top: 1px dashed var(--cz-rule);
  }

  @media (min-width: 720px) {
    .cz-side + .cz-side {
      padding-top: 0;
      padding-left: clamp(20px, 3vw, 28px);
      border-top: 0;
      border-left: 1px dashed var(--cz-rule);
    }
  }

  .cz-side__head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: clamp(10px, 1.6vw, 16px);
    padding-bottom: 8px;
  }

  .cz-side__label {
    font-size: clamp(26px, 5.5vw, 36px);
    line-height: 1;
  }

  .cz-side__rule {
    flex: 1;
    color: var(--cz-rule);
    overflow: hidden;
    white-space: nowrap;
  }

  .cz-side__count {
    flex-shrink: 0;
  }

  .cz-side__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cz-track {
    border-bottom: 1px dotted var(--cz-rule-soft);
  }

  .cz-track:last-child {
    border-bottom: 0;
  }

  .cz-track__row {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 10px;
    align-items: baseline;
    padding: 10px 4px;
    color: var(--cz-ink);
    min-height: 44px;
  }

  .cz-track__row--static {
    cursor: default;
  }

  .cz-track__num {
    color: var(--cz-ink-soft);
  }

  .cz-track__body {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .cz-track__title {
    font-family: var(--cz-sans);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--cz-ink);
    line-height: 1.25;
  }

  .cz-track__feat {
    color: var(--cz-ink-soft);
    font-weight: 400;
  }

  .cz-track__meta {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
    color: var(--cz-ink-soft);
  }

  .cz-track__alt {
    color: var(--cz-marker);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
  }

  .cz-track__year {
    font-size: clamp(20px, 4vw, 28px);
    color: var(--cz-marker);
    transform: rotate(-8deg);
    line-height: 1;
  }

  .cz-track__row:hover .cz-track__title {
    color: var(--cz-marker);
  }

  /* Cue / player ------------------------------------------------------- */
  .cz-track__player {
    margin: 4px 28px 8px 38px;
  }

  @media (max-width: 480px) {
    .cz-track__player {
      margin-left: 38px;
      margin-right: 4px;
    }
  }

  .cz-track__playbtn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    cursor: pointer;
    padding: 6px 10px;
    border: 1px solid var(--cz-rule);
    background: rgba(22, 17, 11, 0.03);
    color: var(--cz-ink);
    border-radius: 2px;
    min-height: 32px;
    transition: border-color 200ms var(--cz-ease);
  }

  .cz-track__playbtn::-webkit-details-marker {
    display: none;
  }

  .cz-track__playbtn:hover {
    border-color: var(--cz-marker);
  }

  .cz-track__playbtn-icon {
    color: var(--cz-marker);
    font-size: 12px;
  }

  details[open] .cz-track__playbtn-icon {
    transform: rotate(90deg);
  }

  .cz-track__embed {
    margin-top: 10px;
    background: var(--cz-stock-2);
    border: 1px solid var(--cz-rule);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 4px 10px -6px rgba(22, 17, 11, 0.4);
  }

  .cz-track__embed iframe {
    display: block;
    width: 100%;
    border: 0;
  }
</style>
