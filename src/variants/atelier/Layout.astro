---
import "@fontsource/ibm-plex-serif/400.css";
import "@fontsource/ibm-plex-serif/500.css";
import "@fontsource/ibm-plex-serif/600.css";
import "@fontsource-variable/inter-tight/wght.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="at"
>
  <slot />
</BaseHtml>

<style is:global>
  .at {
    --at-bg: #ffffff;
    --at-ink: #0a0a0a;
    --at-muted: #6f6f6f;
    --at-faint: #c8c8c8;
    --at-rule: rgba(10, 10, 10, 0.12);
    /* Dusty oxblood. Reserved for selection + focus; never headline color.
       Sourced from the "controlled dusty palette" in references.md. */
    --at-accent: #5a3a3a;
    --at-display:
      "IBM Plex Serif", "IBM Plex Serif Fallback", Georgia, "Times New Roman",
      serif;
    --at-sans:
      "Inter Tight Variable", "Inter Tight", system-ui, -apple-system,
      "Segoe UI", "Helvetica Neue", sans-serif;
    --at-ease: cubic-bezier(0.22, 0.61, 0.36, 1);

    background: var(--at-bg);
    color: var(--at-ink);
    font-family: var(--at-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.6;
    letter-spacing: 0.005em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .at ::selection {
    background: var(--at-accent);
    color: var(--at-bg);
  }

  .at a {
    color: inherit;
    text-decoration: none;
    transition: color 360ms var(--at-ease);
  }

  .at a:hover {
    color: var(--at-accent);
  }

  .at h1,
  .at h2,
  .at h3 {
    font-family: var(--at-display);
    font-weight: 500;
    letter-spacing: -0.015em;
    margin: 0;
  }

  .at :focus-visible {
    outline: 1px solid var(--at-accent);
    outline-offset: 4px;
  }

  .at .at-shell {
    width: 100%;
    max-width: 1360px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }

  .at .at-section {
    padding-block: clamp(112px, 16vw, 224px);
  }

  /* Section divider: thin cantilever-chair side profile, set in line. The
     chair appears in negative space between sections — futuristic-and-retro
     as object, not ornament. */
  .at .at-divider {
    display: flex;
    justify-content: center;
    padding-block: clamp(28px, 4vw, 56px);
  }

  .at .at-divider svg {
    display: block;
    width: clamp(72px, 8vw, 110px);
    height: auto;
    color: var(--at-ink);
    opacity: 0.32;
  }

  .at .at-meta {
    font-family: var(--at-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--at-muted);
    font-variant-numeric: tabular-nums;
  }

  .at .at-plate-num {
    font-family: var(--at-display);
    font-feature-settings:
      "lnum" 1,
      "tnum" 1;
    font-weight: 500;
    font-style: italic;
    color: var(--at-muted);
    letter-spacing: -0.01em;
  }

  @media (prefers-reduced-motion: reduce) {
    .at,
    .at *,
    .at *::before,
    .at *::after {
      transition-duration: 0.001ms !important;
      animation-duration: 0.001ms !important;
    }
  }
</style>
