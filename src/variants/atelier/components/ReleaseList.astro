---
import type { CollectionEntry } from "astro:content";
import { spotifyOpenUrl } from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

const ROMAN = [
  "",
  "I",
  "II",
  "III",
  "IV",
  "V",
  "VI",
  "VII",
  "VIII",
  "IX",
  "X",
  "XI",
  "XII",
  "XIII",
  "XIV",
  "XV",
];

const primaryLink = (release: CollectionEntry<"releases">): string | null => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? null;
};

const formatLabel = (release: CollectionEntry<"releases">): string =>
  release.data.type === "single" ? "Single" : release.data.type.toUpperCase();

const toRoman = (n: number): string => ROMAN[n] ?? String(n);
---

<section class="at-section at-shell" id="music">
  <header class="at-index__head">
    <h2 class="at-index__title">Music</h2>
    <span class="at-meta">{`Plates I\u2013${toRoman(releases.length)}`}</span>
  </header>

  <ol class="at-plates">
    {
      releases.map((release, idx) => {
        const href = primaryLink(release);
        const numeral = toRoman(idx + 1);
        const format = formatLabel(release);
        const RowTag = href ? "a" : "div";

        return (
          <li class="at-plate">
            <RowTag
              class:list={["at-plate__row", !href && "at-plate__row--static"]}
              {...(href ? { href, target: "_blank", rel: "noopener" } : {})}
            >
              <span class="at-plate-num at-plate__num">{numeral}</span>
              <span class="at-plate__title">{release.data.title}</span>
              <span class="at-plate__meta at-meta">{format}</span>
              {href && (
                <span class="at-plate__arrow" aria-hidden="true">
                  &rarr;
                </span>
              )}
            </RowTag>
          </li>
        );
      })
    }
  </ol>
</section>

<style>
  .at-index__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: clamp(48px, 5vw, 80px);
    border-bottom: 1px solid var(--at-rule);
  }

  .at-index__title {
    font-family: var(--at-display);
    font-size: clamp(36px, 4.6vw, 64px);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 0.95;
  }

  .at-plates {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .at-plate {
    border-bottom: 1px solid var(--at-rule);
  }

  .at-plate__row {
    display: grid;
    grid-template-columns: clamp(60px, 8vw, 110px) 1fr auto 24px;
    gap: clamp(20px, 3vw, 56px);
    align-items: baseline;
    padding-block: clamp(36px, 4.5vw, 64px);
    color: var(--at-ink);
  }

  .at-plate__num {
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1;
  }

  .at-plate__title {
    font-family: var(--at-display);
    font-size: clamp(28px, 4vw, 56px);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    transition: color 360ms var(--at-ease);
  }

  .at-plate__meta {
    white-space: nowrap;
  }

  .at-plate__arrow {
    font-size: 18px;
    color: var(--at-faint);
    text-align: right;
    transition:
      color 360ms var(--at-ease),
      transform 360ms var(--at-ease);
  }

  .at-plate__row:hover .at-plate__title,
  .at-plate__row:hover .at-plate__arrow {
    color: var(--at-accent);
  }

  .at-plate__row:hover .at-plate__arrow {
    transform: translateX(6px);
  }

  .at-plate__row--static {
    cursor: default;
  }

  /* Alternate plates lean slightly into the column, like a typeset
     monograph index. Subtle — desktop only. */
  @media (min-width: 960px) {
    .at-plate:nth-child(even) .at-plate__title {
      padding-left: clamp(16px, 2vw, 40px);
    }
  }

  @media (max-width: 720px) {
    .at-plate__row {
      grid-template-columns: 48px 1fr;
      gap: 14px;
      padding-block: clamp(28px, 5vw, 40px);
    }

    .at-plate__meta {
      grid-column: 2;
      padding-top: 6px;
    }

    .at-plate__arrow {
      display: none;
    }
  }
</style>
