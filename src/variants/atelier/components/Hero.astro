---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<header class="at-hero" id="top">
  <figure
    class="at-hero__figure"
    aria-label="Steven Christopher — group on cantilever chairs, monochrome studio still"
  >
    <svg
      class="at-hero__still"
      viewBox="0 0 1600 1100"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
    >
      <defs>
        <radialGradient id="at-vignette" cx="50%" cy="46%" r="68%">
          <stop offset="0%" stop-color="#ffffff" stop-opacity="0" />
          <stop offset="100%" stop-color="#000000" stop-opacity="0.05" />
        </radialGradient>

        <!--
          Breuer Cesca-style cantilever chair, side profile. Continuous
          tubular line. Drawn at native scale; instances are positioned and
          scaled via <use>.
        -->
        <symbol id="at-chair" viewBox="0 0 220 320" overflow="visible">
          <!-- Tubular steel S-frame: floor -> front -> under seat -> back leg loop -->
          <path
            d="M 6 290
               L 122 290
               C 142 290, 154 280, 154 264
               L 154 196
               C 154 180, 142 168, 124 168
               L 24 168
               C 14 168, 6 160, 6 150
               L 6 290 Z"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linejoin="round"
          />
          <!-- Backrest tube continues from rear seat post to top -->
          <path
            d="M 154 196
               L 154 36
               C 154 22, 142 12, 126 12
               L 96 12
               C 80 12, 68 22, 68 36
               L 68 80"
            fill="none"
            stroke="currentColor"
            stroke-width="3"
            stroke-linejoin="round"
          />
          <!-- Seat plane -->
          <rect
            x="20"
            y="158"
            width="138"
            height="14"
            fill="currentColor"
            opacity="0.92"
          />
          <!-- Backrest panel -->
          <rect
            x="74"
            y="40"
            width="76"
            height="50"
            fill="currentColor"
            opacity="0.92"
          />
        </symbol>
      </defs>

      <!-- Paper-bright seamless -->
      <rect width="1600" height="1100" fill="#ffffff" />

      <!-- Faint horizon — wall meets floor -->
      <line
        x1="0"
        y1="820"
        x2="1600"
        y2="820"
        stroke="#0a0a0a"
        stroke-width="1"
        opacity="0.06"
      />

      <!-- Floor shadows under back row -->
      <ellipse
        cx="320"
        cy="780"
        rx="170"
        ry="10"
        fill="#0a0a0a"
        opacity="0.07"
      />
      <ellipse
        cx="800"
        cy="800"
        rx="200"
        ry="11"
        fill="#0a0a0a"
        opacity="0.07"
      />
      <ellipse
        cx="1280"
        cy="780"
        rx="170"
        ry="10"
        fill="#0a0a0a"
        opacity="0.07"
      />

      <!-- Back-left chair + seated figure -->
      <g transform="translate(218, 470) scale(0.92)" color="#0a0a0a">
        <use href="#at-chair" />
        <!-- Seated figure on chair: leather torso + beret head -->
        <path
          d="M 80 -8
             C 80 -32, 100 -48, 122 -48
             C 144 -48, 164 -32, 164 -8
             C 164 4, 158 14, 148 18
             C 162 28, 174 50, 174 80
             C 174 116, 156 168, 130 168
             L 90 168
             C 70 168, 56 154, 56 134
             L 56 90
             C 56 60, 64 38, 80 26
             C 70 18, 68 4, 80 -8 Z"
          fill="currentColor"
          opacity="0.94"
        />
        <!-- Beret peak -->
        <path
          d="M 84 -52
             C 92 -64, 134 -64, 152 -52
             C 156 -42, 154 -34, 144 -32
             L 96 -32
             C 86 -34, 82 -42, 84 -52 Z"
          fill="currentColor"
        />
      </g>

      <!-- Back-center chair + seated figure (slightly larger, central anchor) -->
      <g transform="translate(680, 442) scale(1.08)" color="#0a0a0a">
        <use href="#at-chair" />
        <path
          d="M 64 -16
             C 64 -42, 88 -60, 116 -60
             C 144 -60, 168 -42, 168 -16
             C 168 -2, 160 10, 148 16
             C 166 28, 178 56, 178 92
             C 178 132, 158 184, 128 184
             L 88 184
             C 64 184, 50 168, 50 144
             L 50 96
             C 50 60, 60 36, 78 22
             C 66 12, 60 -2, 64 -16 Z"
          fill="currentColor"
          opacity="0.95"
        />
        <path
          d="M 70 -64
             C 80 -78, 138 -78, 156 -64
             C 162 -52, 158 -44, 146 -42
             L 92 -42
             C 80 -44, 66 -52, 70 -64 Z"
          fill="currentColor"
        />
      </g>

      <!-- Back-right chair + seated figure -->
      <g transform="translate(1180, 470) scale(0.92)" color="#0a0a0a">
        <use href="#at-chair" />
        <path
          d="M 80 -8
             C 80 -32, 100 -48, 122 -48
             C 144 -48, 164 -32, 164 -8
             C 164 4, 158 14, 148 18
             C 162 28, 174 50, 174 80
             C 174 116, 156 168, 130 168
             L 90 168
             C 70 168, 56 154, 56 134
             L 56 90
             C 56 60, 64 38, 80 26
             C 70 18, 68 4, 80 -8 Z"
          fill="currentColor"
          opacity="0.94"
        />
        <path
          d="M 84 -52
             C 92 -64, 134 -64, 152 -52
             C 156 -42, 154 -34, 144 -32
             L 96 -32
             C 86 -34, 82 -42, 84 -52 Z"
          fill="currentColor"
        />
      </g>

      <!-- Foreground floor shadow (photographer) -->
      <ellipse
        cx="800"
        cy="1010"
        rx="280"
        ry="14"
        fill="#0a0a0a"
        opacity="0.10"
      />

      <!-- Foreground figure: photographer pointing camera at viewer.
           The photographed photographing — meta gesture from reference 02. -->
      <g transform="translate(620, 540)" color="#0a0a0a">
        <!-- Body / leather jacket silhouette -->
        <path
          d="M 100 220
             C 60 220, 36 200, 30 168
             L 22 92
             C 18 64, 30 38, 56 26
             L 92 14
             C 100 12, 108 12, 116 12
             L 124 12
             C 132 12, 140 12, 148 14
             L 184 26
             C 210 38, 222 64, 218 92
             L 210 168
             C 204 200, 180 220, 140 220
             L 100 220 Z"
          fill="currentColor"
          opacity="0.97"
        />
        <!-- Arms folded up holding camera at face -->
        <path
          d="M 56 90
             C 60 80, 76 76, 88 86
             L 96 96
             C 110 100, 124 100, 138 100
             L 152 100
             C 164 100, 180 80, 184 90
             C 192 110, 188 132, 168 138
             L 152 138
             L 152 156
             L 88 156
             L 88 138
             L 72 138
             C 52 132, 48 110, 56 90 Z"
          fill="currentColor"
          opacity="0.97"
        />
        <!-- Head -->
        <path
          d="M 92 14
             C 92 -10, 110 -28, 132 -28
             C 154 -28, 172 -10, 172 14
             L 172 32
             C 172 50, 158 64, 140 64
             L 124 64
             C 106 64, 92 50, 92 32
             L 92 14 Z"
          fill="currentColor"
        />
        <!-- Beret -->
        <path
          d="M 78 -32
             C 90 -50, 174 -50, 188 -32
             C 192 -22, 188 -14, 178 -12
             L 86 -12
             C 76 -14, 74 -22, 78 -32 Z"
          fill="currentColor"
        />
        <!-- Camera body — rectangle held at face level, lens pointing at viewer -->
        <rect
          x="106"
          y="22"
          width="56"
          height="36"
          fill="#0a0a0a"
        />
        <circle cx="134" cy="40" r="11" fill="#ffffff" />
        <circle cx="134" cy="40" r="5" fill="#0a0a0a" />
        <!-- Hands gripping camera -->
        <path
          d="M 96 28
             C 92 24, 92 56, 100 60
             L 110 60
             L 110 22
             L 96 28 Z"
          fill="currentColor"
        />
        <path
          d="M 172 28
             C 176 24, 176 56, 168 60
             L 158 60
             L 158 22
             L 172 28 Z"
          fill="currentColor"
        />
      </g>

      <rect width="1600" height="1100" fill="url(#at-vignette)" />
    </svg>
  </figure>

  <div class="at-hero__caption at-shell">
    <p class="at-hero__name">{name}</p>
    <p class="at-meta at-hero__plate">Plate I &mdash; Cantilever</p>
  </div>
</header>

<style>
  .at-hero {
    position: relative;
  }

  .at-hero__figure {
    margin: 0;
    background: #ffffff;
    overflow: hidden;
  }

  .at-hero__still {
    display: block;
    width: 100%;
    height: clamp(64vh, 76vw, 92vh);
    max-height: 940px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.02);
  }

  .at-hero__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: clamp(20px, 2.4vw, 32px);
  }

  .at-hero__name {
    margin: 0;
    font-family: var(--at-display);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--at-ink);
  }

  .at-hero__plate {
    margin: 0;
  }
</style>
