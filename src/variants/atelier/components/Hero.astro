---
import { Picture } from "astro:assets";
import heroImage from "../../../assets/HeroImage.jpg";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<header class="at-hero" id="top">
  <figure
    class="at-hero__figure"
    aria-label={`${name} — portrait, monochrome plate`}
  >
    <Picture
      class="at-hero__still"
      src={heroImage}
      alt={`Portrait of ${name}`}
      widths={[640, 1080, 1600, 2400]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={78}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>

  <div class="at-hero__caption at-shell">
    <p class="at-hero__name">{name}</p>
    <p class="at-meta at-hero__plate">Plate I &mdash; Portrait</p>
  </div>
</header>

<style>
  .at-hero {
    position: relative;
  }

  .at-hero__figure {
    margin: 0;
    background: #ffffff;
    overflow: hidden;
  }

  .at-hero__still {
    display: block;
    width: 100%;
    height: clamp(64vh, 76vw, 92vh);
    max-height: 940px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.04);
  }

  .at-hero__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: clamp(20px, 2.4vw, 32px);
  }

  .at-hero__name {
    margin: 0;
    font-family: var(--at-display);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--at-ink);
  }

  .at-hero__plate {
    margin: 0;
  }
</style>
