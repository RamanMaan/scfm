---
interface Props {
  name: string;
}

const { name } = Astro.props;

const links = [
  { label: "Music", href: "#music" },
  { label: "Video", href: "#video" },
  { label: "Contact", href: "#contact" },
];
---

<nav class="at-nav at-shell" aria-label="Primary">
  <a class="at-nav__mark" href="#top">{name}</a>
  <ul class="at-nav__list">
    {
      links.map((link) => (
        <li>
          <a class="at-nav__link" href={link.href}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .at-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: clamp(20px, 2vw, 28px);
  }

  .at-nav__mark {
    font-family: var(--at-display);
    font-size: clamp(16px, 1.6vw, 18px);
    font-weight: 500;
    letter-spacing: -0.005em;
    color: var(--at-ink);
  }

  .at-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(18px, 2.4vw, 30px);
  }

  .at-nav__link {
    font-family: var(--at-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--at-ink);
  }

  @media (max-width: 480px) {
    .at-nav__list {
      gap: 16px;
    }
  }
</style>
