---
/**
 * Cantilever-chair side-profile, in line. Sits between sections as the
 * structural motif of the variant — the *futuristic-and-retro* tension
 * expressed as object, not ornament.
 */
---

<div class="at-divider" aria-hidden="true">
  <svg
    viewBox="0 0 220 320"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    stroke="currentColor"
    stroke-width="3"
    stroke-linejoin="round"
    stroke-linecap="round"
  >
    <path
      d="M 6 290
         L 122 290
         C 142 290, 154 280, 154 264
         L 154 196
         C 154 180, 142 168, 124 168
         L 24 168
         C 14 168, 6 160, 6 150
         L 6 290 Z"
    />
    <path
      d="M 154 196
         L 154 36
         C 154 22, 142 12, 126 12
         L 96 12
         C 80 12, 68 22, 68 36
         L 68 80"
    />
    <line x1="20" y1="166" x2="158" y2="166" />
    <line x1="74" y1="40" x2="150" y2="40" />
  </svg>
</div>
