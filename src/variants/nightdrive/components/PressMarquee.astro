---
import type { CollectionEntry } from "astro:content";

interface Props {
  press: CollectionEntry<"press">[];
}

const { press } = Astro.props;

// Duplicate the list for a seamless loop. Each cycle of the keyframe travels
// exactly -50% so the second copy aligns where the first started.
// When there are very few quotes, pre-pad before the duplication so the visible
// strip never feels sparse.
const base =
  press.length < 4 ? [...press, ...press, ...press, ...press] : [...press];
const looped = base.length > 0 ? [...base, ...base] : [];
const halfMark = base.length; // first half of the looped track
---

{
  press.length > 0 && (
    <aside
      class="nd-marquee"
      aria-label="Press"
      role="complementary"
      tabindex="0"
    >
      <p class="nd-tag nd-marquee__label" aria-hidden="true">
        Press / The wire
      </p>
      <div class="nd-marquee__viewport">
        <ul class="nd-marquee__track" aria-hidden="false">
          {looped.map((entry, idx) => (
            <li class="nd-marquee__item" aria-hidden={idx >= halfMark}>
              <a
                class="nd-marquee__link"
                href={entry.data.sourceUrl}
                target="_blank"
                rel="noopener"
                tabindex={idx >= halfMark ? -1 : 0}
              >
                <span class="nd-marquee__quote">&ldquo;{entry.data.quote}&rdquo;</span>
                <span class="nd-marquee__src nd-tag">
                  &mdash; {entry.data.source}
                </span>
              </a>
              <span class="nd-marquee__sep" aria-hidden="true">&loz;</span>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  )
}

<style>
  .nd-marquee {
    position: relative;
    margin-top: clamp(40px, 6vw, 80px);
    border-top: 1px solid var(--nd-rule);
    border-bottom: 1px solid var(--nd-rule);
    background: linear-gradient(
      180deg,
      rgba(15, 29, 74, 0.32) 0%,
      rgba(15, 29, 74, 0.12) 100%
    );
    overflow: hidden;
    padding-block: clamp(20px, 2.6vw, 28px);
  }

  .nd-marquee__label {
    position: absolute;
    top: 8px;
    left: clamp(20px, 5vw, 56px);
    color: var(--nd-amber);
    opacity: 0.78;
    pointer-events: none;
  }

  .nd-marquee__viewport {
    position: relative;
    overflow: hidden;
    margin-top: clamp(12px, 1.4vw, 18px);
    /* Soft fade at the seams so re-loop is invisible. */
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .nd-marquee__track {
    display: flex;
    align-items: center;
    gap: clamp(28px, 4vw, 56px);
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
    animation: nd-scroll 64s linear infinite;
    will-change: transform;
  }

  .nd-marquee:hover .nd-marquee__track,
  .nd-marquee:focus-within .nd-marquee__track {
    animation-play-state: paused;
  }

  @keyframes nd-scroll {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  .nd-marquee__item {
    display: flex;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
    margin: 0;
    padding: 0;
    white-space: nowrap;
  }

  .nd-marquee__link {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    color: var(--nd-cream);
    transition: color 320ms var(--nd-ease);
  }

  .nd-marquee__quote {
    font-family: var(--nd-serif);
    font-style: italic;
    font-weight: 400;
    font-variation-settings:
      "SOFT" 100,
      "opsz" 144;
    font-size: clamp(18px, 2vw, 24px);
    letter-spacing: -0.005em;
    color: var(--nd-cream);
  }

  .nd-marquee__src {
    color: var(--nd-amber);
  }

  .nd-marquee__link:hover,
  .nd-marquee__link:focus-visible {
    color: var(--nd-amber);
  }

  .nd-marquee__link:hover .nd-marquee__quote,
  .nd-marquee__link:focus-visible .nd-marquee__quote {
    color: var(--nd-amber);
  }

  .nd-marquee__sep {
    color: var(--nd-amber);
    opacity: 0.45;
    font-size: 14px;
  }

  @media (prefers-reduced-motion: reduce) {
    .nd-marquee__track {
      animation: none !important;
      transform: none !important;
    }
    .nd-marquee__viewport {
      overflow-x: auto;
    }
  }
</style>
