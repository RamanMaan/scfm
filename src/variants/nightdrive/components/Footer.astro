---
import type { CollectionEntry } from "astro:content";
import { orderedSocials } from "../../../lib/socials";

interface Props {
  artist: CollectionEntry<"artist">;
}

const { artist } = Astro.props;
const socials = orderedSocials(artist.data.socials);
const year = new Date().getUTCFullYear();
---

<footer class="nd-section nd-shell nd-foot" id="contact">
  <div class="nd-foot__grid">
    <div class="nd-foot__signoff">
      <p class="nd-tag">Sign off / Last call</p>
      <p class="nd-foot__line">
        That&rsquo;s all from <span class="nd-foot__here">{artist.data.basedIn}</span>.
      </p>
      <p class="nd-foot__line nd-foot__line--small">
        Originally broadcasting from {artist.data.origin}.
        <br />
        Stay warm out there.
      </p>
    </div>

    <div class="nd-foot__band">
      <p class="nd-tag">Find the frequency</p>
      <ul class="nd-foot__socials">
        {
          socials.map(({ url, label }) => (
            <li>
              <a
                class="nd-foot__link"
                href={url}
                target="_blank"
                rel="noopener"
                aria-label={label}
              >
                <span class="nd-foot__platform">{label}</span>
                <span class="nd-foot__arrow" aria-hidden="true">
                  &nearr;
                </span>
              </a>
            </li>
          ))
        }
        <li>
          <a
            class="nd-foot__link nd-foot__link--mail"
            href="mailto:hello@stevenchristopher.com"
            aria-label={`Email ${artist.data.name}`}
          >
            <span class="nd-foot__platform">Mail</span>
            <span class="nd-foot__arrow" aria-hidden="true">
              &nearr;
            </span>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="nd-foot__base">
    <p class="nd-tag nd-tag--dim">
      &copy; {year} {artist.data.name} &middot; ALL RIGHTS RESERVED
    </p>
    <p class="nd-tag nd-tag--dim">102.7 FM &middot; STAY TUNED</p>
  </div>
</footer>

<style>
  .nd-foot {
    padding-top: clamp(48px, 6vw, 88px);
  }

  .nd-foot__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(36px, 5vw, 64px);
    padding-bottom: clamp(40px, 5vw, 64px);
    border-bottom: 1px solid var(--nd-rule);
  }

  @media (min-width: 720px) {
    .nd-foot__grid {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    }
  }

  .nd-foot__signoff {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .nd-foot__line {
    margin: 0;
    font-family: var(--nd-serif);
    font-style: italic;
    font-weight: 400;
    font-variation-settings:
      "SOFT" 100,
      "opsz" 144;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--nd-cream);
    text-wrap: balance;
  }

  .nd-foot__here {
    color: var(--nd-amber);
    text-shadow: 0 0 18px rgba(255, 177, 74, 0.32);
  }

  .nd-foot__line--small {
    font-family: var(--nd-sans);
    font-style: normal;
    font-size: 14px;
    line-height: 1.6;
    color: var(--nd-cream-dim);
    letter-spacing: 0;
    margin-top: 4px;
  }

  .nd-foot__band {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .nd-foot__socials {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nd-foot__socials li {
    border-top: 1px solid var(--nd-rule-warm);
  }

  .nd-foot__socials li:last-child {
    border-bottom: 1px solid var(--nd-rule-warm);
  }

  .nd-foot__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    min-height: 52px;
    color: var(--nd-cream);
    transition:
      color 320ms var(--nd-ease),
      padding 320ms var(--nd-ease);
  }

  .nd-foot__platform {
    font-family: var(--nd-serif);
    font-style: italic;
    font-weight: 400;
    font-variation-settings:
      "SOFT" 100,
      "opsz" 144;
    font-size: clamp(20px, 2.4vw, 26px);
    letter-spacing: -0.01em;
  }

  .nd-foot__arrow {
    font-family: var(--nd-mono);
    font-size: 14px;
    color: var(--nd-cream-faint);
    transition:
      color 320ms var(--nd-ease),
      transform 320ms var(--nd-ease);
  }

  .nd-foot__link:hover,
  .nd-foot__link:focus-visible {
    color: var(--nd-amber);
    padding-inline: 6px 0;
  }

  .nd-foot__link:hover .nd-foot__arrow,
  .nd-foot__link:focus-visible .nd-foot__arrow {
    color: var(--nd-amber);
    transform: translate(2px, -2px);
  }

  .nd-foot__base {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding-top: clamp(20px, 2.4vw, 32px);
    flex-wrap: wrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .nd-foot__link,
    .nd-foot__arrow {
      transition: none !important;
    }
  }
</style>
