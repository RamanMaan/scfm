---
import type { CollectionEntry } from "astro:content";
import { formatYear } from "../../../lib/formatDate";
import { spotifyOpenUrl } from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

const primaryLink = (release: CollectionEntry<"releases">): string | null => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? null;
};
---

<section class="ed-section ed-section--ruled ed-shell" id="music">
  <ol class="ed-list">
    {
      releases.map((release, idx) => {
        const href = primaryLink(release);
        const num = String(idx + 1).padStart(2, "0");
        const year = formatYear(release.data.releaseDate);

        return (
          <li class="ed-list__item">
            {href ? (
              <a class="ed-list__row" href={href} target="_blank" rel="noopener">
                <span class="ed-list__num">{num}</span>
                <span class="ed-list__title">
                  <em>{release.data.title}</em>
                </span>
                <span class="ed-list__year">{year}</span>
                <span class="ed-list__arrow" aria-hidden="true">
                  &rarr;
                </span>
              </a>
            ) : (
              <div class="ed-list__row ed-list__row--static">
                <span class="ed-list__num">{num}</span>
                <span class="ed-list__title">
                  <em>{release.data.title}</em>
                </span>
                <span class="ed-list__year">{year}</span>
                <span class="ed-list__arrow" aria-hidden="true" />
              </div>
            )}
          </li>
        );
      })
    }
  </ol>
</section>

<style>
  .ed-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ed-list__item {
    border-bottom: 1px solid var(--ed-rule);
  }

  .ed-list__item:first-child {
    border-top: 1px solid var(--ed-rule);
  }

  .ed-list__row {
    display: grid;
    grid-template-columns: 56px 1fr auto 24px;
    gap: clamp(16px, 3vw, 40px);
    align-items: baseline;
    padding-block: clamp(20px, 2.4vw, 32px);
    color: var(--ed-ink);
  }

  .ed-list__num {
    font-family: var(--ed-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ed-muted);
    font-variant-numeric: tabular-nums;
  }

  .ed-list__title {
    font-family: var(--ed-display);
    font-size: clamp(28px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: lowercase;
    transition: color 0.35s ease;
  }

  .ed-list__title em {
    font-style: normal;
  }

  .ed-list__year {
    font-family: var(--ed-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ed-muted);
    font-variant-numeric: tabular-nums;
  }

  .ed-list__arrow {
    font-family: var(--ed-sans);
    font-size: 14px;
    color: var(--ed-faint);
    transition:
      color 0.35s ease,
      transform 0.35s ease;
    text-align: right;
  }

  .ed-list__row:hover .ed-list__title,
  .ed-list__row:hover .ed-list__arrow {
    color: var(--ed-accent);
  }

  .ed-list__row:hover .ed-list__arrow {
    transform: translateX(4px);
  }

  .ed-list__row--static {
    cursor: default;
  }

  @media (max-width: 600px) {
    .ed-list__row {
      grid-template-columns: 36px 1fr auto;
      gap: 14px;
    }

    .ed-list__arrow {
      display: none;
    }
  }
</style>
