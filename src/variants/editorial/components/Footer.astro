---
import type { CollectionEntry } from "astro:content";
import { orderedSocials } from "../../../lib/socials";

interface Props {
  artist: CollectionEntry<"artist">;
}

const { artist } = Astro.props;
const socials = orderedSocials(artist.data.socials);
---

<footer class="ed-section ed-section--ruled ed-shell" id="contact">
  <header class="ed-index__head">
    <span class="ed-meta">Index — Contact</span>
    <span class="ed-meta">{String(socials.length).padStart(2, "0")}</span>
  </header>

  <div class="ed-foot__lede">
    <p class="ed-foot__line">
      <span class="ed-foot__italic">Inquiries, listening, &amp; press.</span>
    </p>
  </div>

  <ul class="ed-foot__socials">
    {
      socials.map(({ url, label }) => (
        <li>
          <a class="ed-foot__social" href={url} target="_blank" rel="noopener">
            {label}
            <span class="ed-foot__arrow" aria-hidden="true">
              &nearr;
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="ed-foot__base">
    <p class="ed-meta">&copy; {artist.data.name}</p>
    <p class="ed-meta">All rights reserved</p>
  </div>
</footer>

<style>
  .ed-index__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: clamp(28px, 3vw, 44px);
  }

  .ed-foot__lede {
    padding-block: clamp(8px, 1vw, 16px) clamp(48px, 6vw, 80px);
    border-top: 1px solid var(--ed-rule);
  }

  .ed-foot__line {
    margin: clamp(28px, 3vw, 40px) 0 0;
    font-family: var(--ed-display);
    font-size: clamp(28px, 3.4vw, 52px);
    font-weight: 400;
    font-variation-settings:
      "opsz" 144,
      "SOFT" 60;
    line-height: 1;
    letter-spacing: -0.012em;
    text-transform: lowercase;
    color: var(--ed-ink);
  }

  .ed-foot__italic {
    font-style: italic;
    font-variation-settings:
      "opsz" 144,
      "SOFT" 80;
  }

  .ed-foot__socials {
    list-style: none;
    margin: 0 0 clamp(64px, 8vw, 96px);
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0;
    border-top: 1px solid var(--ed-rule);
  }

  .ed-foot__socials li {
    border-bottom: 1px solid var(--ed-rule);
  }

  .ed-foot__social {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 18px 0;
    font-family: var(--ed-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ed-ink);
  }

  .ed-foot__arrow {
    color: var(--ed-faint);
    font-size: 14px;
    transition:
      color 0.4s ease,
      transform 0.4s ease;
  }

  .ed-foot__social:hover .ed-foot__arrow {
    color: var(--ed-accent);
    transform: translate(2px, -2px);
  }

  .ed-foot__base {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: clamp(20px, 2vw, 28px);
    border-top: 1px solid var(--ed-rule);
  }

  @media (max-width: 480px) {
    .ed-foot__base {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
  }
</style>
