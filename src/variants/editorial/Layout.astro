---
import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="ed"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    slot="head"
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,0..100;1,9..144,300..600,0..100&family=Inter:wght@400;500&display=swap"
  />
  <slot />
</BaseHtml>

<style is:global>
  .ed {
    --ed-bg: #f3efe7;
    --ed-ink: #161513;
    --ed-muted: #6f6b62;
    --ed-faint: #b8b2a6;
    --ed-rule: rgba(22, 21, 19, 0.14);
    --ed-accent: #6a3030;

    --ed-display: "Fraunces", Georgia, serif;
    --ed-sans:
      "Inter", system-ui, -apple-system, "Segoe UI", "Helvetica Neue",
      sans-serif;

    background: var(--ed-bg);
    color: var(--ed-ink);
    font-family: var(--ed-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0.005em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .ed ::selection {
    background: var(--ed-ink);
    color: var(--ed-bg);
  }

  .ed a {
    color: inherit;
    text-decoration: none;
    transition:
      color 0.4s ease,
      opacity 0.4s ease;
  }

  .ed a:hover {
    color: var(--ed-accent);
  }

  .ed h1,
  .ed h2,
  .ed h3 {
    margin: 0;
    font-weight: 400;
  }

  .ed :focus-visible {
    outline: 1px solid var(--ed-accent);
    outline-offset: 4px;
  }

  .ed .ed-shell {
    width: 100%;
    max-width: 1480px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 56px);
  }

  .ed .ed-section {
    padding-block: clamp(96px, 12vw, 176px);
  }

  .ed .ed-section--ruled {
    border-top: 1px solid var(--ed-rule);
  }

  .ed .ed-meta {
    font-family: var(--ed-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ed-muted);
    font-variant-numeric: tabular-nums;
  }
</style>
