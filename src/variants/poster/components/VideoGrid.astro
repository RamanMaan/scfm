---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  videos: CollectionEntry<"videos">[];
  channelUrl: string;
}

const { videos, channelUrl } = Astro.props;

const watchUrl = (video: CollectionEntry<"videos">): string => {
  if (video.data.youtubeUrl) return video.data.youtubeUrl;
  if (video.data.youtubeId) {
    return `https://www.youtube.com/watch?v=${video.data.youtubeId}`;
  }
  return channelUrl;
};

const thumb = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<section class="po-section po-shell" id="video">
  <header class="po-section__head">
    <h2 class="po-section__title po-ink2" data-text="Visuals">Visuals</h2>
    <span class="po-section__num">No. 03 / On Screen</span>
  </header>

  {
    videos.length > 0 ? (
      <ul class="po-vid">
        {videos.map((video, idx) => {
          const id = video.data.youtubeId;
          const tilt = idx % 2 === 0 ? "-1.2deg" : "1deg";
          return (
            <li class="po-vid__item" style={`--po-tilt:${tilt}`}>
              <a
                class="po-vid__card"
                href={watchUrl(video)}
                target="_blank"
                rel="noopener"
              >
                <span class="po-vid__media" aria-hidden="true">
                  {id ? (
                    <Image
                      src={thumb(id)}
                      alt=""
                      width={480}
                      height={360}
                      widths={[320, 480, 640]}
                      sizes="(min-width: 720px) 360px, 80vw"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <span class="po-vid__placeholder po-halftone" />
                  )}
                  <span class="po-vid__scrim" />
                </span>
                <span class="po-vid__play" aria-hidden="true">
                  ▶ PLAY
                </span>
                <span class="po-vid__body">
                  <span class="po-vid__title po-ink2" data-text={video.data.title.toUpperCase()}>
                    {video.data.title.toUpperCase()}
                  </span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <a
        class="po-vid__empty"
        href={channelUrl}
        target="_blank"
        rel="noopener"
      >
        <span class="po-vid__empty-title po-ink2" data-text="Channel →">Channel →</span>
      </a>
    )
  }
</section>

<style>
  .po-vid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: clamp(20px, 3vw, 36px);
  }

  .po-vid__item {
    transform: rotate(var(--po-tilt, 0deg));
  }

  .po-vid__card {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    color: var(--po-ink);
    background: var(--po-paper);
    border: 4px solid var(--po-ink);
    box-shadow: 6px 6px 0 var(--po-pink);
    isolation: isolate;
    transition: transform 220ms ease-out, box-shadow 220ms ease-out;
  }

  .po-vid__card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 10px 10px 0 var(--po-pink);
  }

  .po-vid__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .po-vid__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Knock out to a single ink: high contrast, desaturate. */
    filter: contrast(1.4) saturate(0) brightness(0.95);
    mix-blend-mode: multiply;
  }

  .po-vid__placeholder {
    position: absolute;
    inset: 0;
    --po-dot: 8px;
    --po-dot-r: 35%;
    --po-dot-color: var(--po-ink);
    background-color: var(--po-paper-tint);
  }

  .po-vid__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(255, 51, 102, 0.4) 0%,
        rgba(255, 51, 102, 0.15) 40%,
        rgba(255, 51, 102, 0) 70%
      );
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .po-vid__play {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    background: var(--po-pink);
    color: var(--po-paper);
    padding: 6px 10px;
    font-family: var(--po-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1;
    border: 2px solid var(--po-ink);
    transform: rotate(2deg);
  }

  .po-vid__body {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    z-index: 1;
  }

  .po-vid__title {
    display: inline-block;
    font-family: var(--po-display);
    font-weight: 900;
    font-size: clamp(20px, 2.6vw, 28px);
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    background: var(--po-paper);
    padding: 6px 10px;
    border: 2px solid var(--po-ink);
    max-width: 100%;
  }

  .po-vid__empty {
    display: inline-block;
    border: 4px solid var(--po-ink);
    padding: clamp(20px, 3vw, 32px) clamp(28px, 4vw, 44px);
    box-shadow: 8px 8px 0 var(--po-pink);
    transform: rotate(-1deg);
  }

  .po-vid__empty-title {
    font-family: var(--po-display);
    font-weight: 900;
    font-size: clamp(36px, 6vw, 72px);
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .po-vid__item {
      transform: none;
    }
    .po-vid__card:hover {
      transform: none;
    }
  }
</style>
