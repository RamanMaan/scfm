---
interface Props {
  name: string;
  tagline: string;
  origin: string;
  basedIn: string;
}

const { name, tagline, origin, basedIn } = Astro.props;

const [first, last] = name.split(" ");
---

<header class="po-hero" id="top">
  <div class="po-hero__paperbleed" aria-hidden="true"></div>

  <!-- The cornerstone: stacked display blocks. The whole thing is the marquee.
       Each row is rendered with the two-ink stack utility (data-text on a
       single span gets the two-ink trick). -->
  <div class="po-hero__stack">
    <div class="po-hero__row po-hero__row--name">
      <span class="po-hero__word po-ink2" data-text={first?.toUpperCase()}>
        {first?.toUpperCase()}
      </span>
    </div>

    <!-- Middle row: tour text + barcode block, breaking the symmetry. -->
    <div class="po-hero__row po-hero__row--inter">
      <span class="po-hero__inter">
        <span class="po-hero__bullet" aria-hidden="true">★</span>
        Live
        <span class="po-hero__sep" aria-hidden="true"></span>
        Loud
        <span class="po-hero__sep" aria-hidden="true"></span>
        Once
      </span>
      <span class="po-hero__year po-ink2" data-text="'26">'26</span>
    </div>

    <div class="po-hero__row po-hero__row--name">
      <span class="po-hero__word po-ink2" data-text={last?.toUpperCase()}>
        {last?.toUpperCase()}
      </span>
    </div>

    <div class="po-hero__row po-hero__row--tour">
      <span class="po-hero__tour po-ink2" data-text="TOUR 2026">TOUR 2026</span>
    </div>
  </div>

  <!-- Halftone "portrait" knockout panel — single-ink, dot-grid. The portrait
       asset isn't a hard requirement, so we render a giant pure-halftone slab
       as the focal image. Reads as ink-on-paper poster art. -->
  <aside class="po-hero__plate" aria-hidden="true">
    <div class="po-hero__plate-dots po-halftone"></div>
    <div class="po-hero__plate-tag">
      <span class="po-tag">SOLO TOUR / NEW MATERIAL</span>
    </div>
    <svg
      class="po-hero__starburst"
      viewBox="0 0 200 200"
      role="img"
      aria-hidden="true"
    >
      <g transform="translate(100 100)">
        {
          Array.from({ length: 24 }).map((_, i) => (
            <rect
              x="-3"
              y="-100"
              width="6"
              height="100"
              fill="currentColor"
              transform={`rotate(${(360 / 24) * i})`}
            />
          ))
        }
        <circle r="56" fill="var(--po-paper)" />
        <circle r="56" fill="currentColor" opacity="0.02" />
      </g>
      <text
        x="100"
        y="92"
        text-anchor="middle"
        font-family="var(--po-display)"
        font-weight="900"
        font-size="26"
        fill="currentColor"
      >
        NEW
      </text>
      <text
        x="100"
        y="118"
        text-anchor="middle"
        font-family="var(--po-display)"
        font-weight="900"
        font-size="26"
        fill="currentColor"
      >
        LP
      </text>
    </svg>
  </aside>

  <!-- The credit/meta strip at the bottom of the hero. Loud caps. -->
  <div class="po-hero__credits">
    <p class="po-hero__tag">
      <span class="po-hero__credit-label">An Evening With</span>
      <span class="po-hero__credit-name">{name}</span>
    </p>
    <p class="po-hero__bio">{tagline}</p>
    <p class="po-hero__where">
      <span class="po-tag">{origin}</span>
      <span class="po-hero__arrow" aria-hidden="true">→</span>
      <span class="po-tag po-tag--pink">{basedIn}</span>
    </p>
  </div>
</header>

<style>
  .po-hero {
    position: relative;
    padding: clamp(24px, 4vw, 56px) clamp(16px, 4vw, 40px)
      clamp(40px, 6vw, 80px);
    overflow: hidden;
  }

  /* Big bleed of pink in the corner — fakes the registration error spilling
     past the trim line. */
  .po-hero__paperbleed {
    position: absolute;
    top: 0;
    right: -6%;
    width: 60%;
    height: 30%;
    background: var(--po-pink);
    mix-blend-mode: multiply;
    opacity: 0.85;
    transform: rotate(-3deg) translateY(-30%);
    pointer-events: none;
  }

  .po-hero__stack {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(4px, 0.8vw, 10px);
    margin-bottom: clamp(24px, 4vw, 48px);
  }

  .po-hero__row {
    line-height: 0.82;
  }

  .po-hero__row--name {
    font-family: var(--po-display);
    font-weight: 900;
    font-size: clamp(72px, 22vw, 240px);
    text-transform: uppercase;
    letter-spacing: -0.025em;
  }

  /* The middle "inter" row sits between the two name rows. Smaller, splashy. */
  .po-hero__row--inter {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-block: clamp(6px, 1vw, 12px);
    font-family: var(--po-display);
    font-weight: 700;
    font-size: clamp(20px, 3vw, 36px);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--po-ink);
  }

  .po-hero__inter {
    display: inline-flex;
    align-items: center;
    gap: clamp(8px, 1.4vw, 14px);
  }

  .po-hero__bullet {
    color: var(--po-pink);
    font-size: 1.4em;
    line-height: 0;
    display: inline-block;
    transform: translateY(-2px);
  }

  .po-hero__sep {
    width: clamp(20px, 4vw, 56px);
    height: 3px;
    background: var(--po-ink);
    display: inline-block;
  }

  .po-hero__year {
    font-family: var(--po-display);
    font-size: clamp(36px, 7vw, 96px);
    font-weight: 900;
    line-height: 0.82;
    color: var(--po-pink);
  }

  .po-hero__row--tour {
    font-family: var(--po-display);
    font-weight: 900;
    font-size: clamp(48px, 14vw, 160px);
    text-transform: uppercase;
    line-height: 0.82;
    letter-spacing: 0.02em;
    text-align: right;
  }

  /* Two-ink word: needs whitespace preserved so pseudos sit on glyphs. */
  .po-hero__word,
  .po-hero__tour,
  .po-hero__year {
    display: inline-block;
    position: relative;
    white-space: nowrap;
  }

  /* Halftone plate: portrait stand-in. Positioned to sit BEHIND the type. */
  .po-hero__plate {
    position: absolute;
    top: clamp(140px, 22vw, 240px);
    right: clamp(-30px, -2vw, 0px);
    width: clamp(160px, 30vw, 380px);
    height: clamp(160px, 30vw, 380px);
    pointer-events: none;
    z-index: -1;
  }

  .po-hero__plate-dots {
    --po-dot: clamp(6px, 1vw, 14px);
    --po-dot-r: 30%;
    --po-dot-color: var(--po-ink);
    position: absolute;
    inset: 0;
    mix-blend-mode: multiply;
    /* Knock out — masked into a soft circle so it reads as a portrait blob. */
    -webkit-mask-image: radial-gradient(
      circle at 50% 45%,
      #000 38%,
      rgba(0, 0, 0, 0.6) 55%,
      transparent 72%
    );
    mask-image: radial-gradient(
      circle at 50% 45%,
      #000 38%,
      rgba(0, 0, 0, 0.6) 55%,
      transparent 72%
    );
    opacity: 0.55;
  }

  .po-hero__starburst {
    position: absolute;
    bottom: -12%;
    right: -6%;
    width: clamp(110px, 20vw, 200px);
    height: clamp(110px, 20vw, 200px);
    color: var(--po-pink);
    mix-blend-mode: multiply;
    transform: rotate(8deg);
    animation: po-spin 60s linear infinite;
    transform-origin: center;
  }

  @keyframes po-spin {
    to {
      transform: rotate(368deg);
    }
  }

  .po-hero__plate-tag {
    position: absolute;
    left: 0;
    bottom: 8%;
    transform: rotate(-6deg);
    color: var(--po-ink);
  }

  .po-hero__credits {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(10px, 1.4vw, 14px);
    padding-top: clamp(16px, 2.4vw, 24px);
    border-top: 4px solid var(--po-ink);
    max-width: 720px;
  }

  .po-hero__tag {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin: 0;
    font-family: var(--po-display);
    text-transform: uppercase;
  }

  .po-hero__credit-label {
    font-family: var(--po-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.24em;
    color: var(--po-pink);
  }

  .po-hero__credit-name {
    font-family: var(--po-display);
    font-weight: 900;
    font-size: clamp(22px, 3vw, 30px);
    letter-spacing: 0.02em;
  }

  .po-hero__bio {
    margin: 0;
    font-family: var(--po-mono);
    font-size: clamp(13px, 1.4vw, 15px);
    line-height: 1.45;
    color: var(--po-ink);
    max-width: 50ch;
  }

  .po-hero__where {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 4px 0 0;
    flex-wrap: wrap;
  }

  .po-hero__arrow {
    font-family: var(--po-display);
    font-weight: 900;
    font-size: 18px;
    color: var(--po-pink);
  }

  .po-tag--pink {
    color: var(--po-pink);
    background: var(--po-paper);
    border-color: currentColor;
  }

  @media (prefers-reduced-motion: reduce) {
    .po-hero__starburst {
      animation: none;
    }
  }
</style>
