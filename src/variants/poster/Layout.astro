---
/**
 * Poster — 2-color risograph gig-flyer aesthetic.
 *
 * Color system is two inks (hot pink + ink-blue) printed on a slightly warm
 * off-white paper stock. Anywhere both inks land you get the muddy plum
 * overprint — that's `mix-blend-mode: multiply` doing the work. The whole
 * page deliberately leans loud; restraint lives in the other variants.
 */

import "@fontsource/big-shoulders-display/700.css";
import "@fontsource/big-shoulders-display/900.css";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="po"
>
  <slot />
</BaseHtml>

<style is:global>
  .po {
    /* Two inks + paper. Everything else is composed from these. */
    --po-paper: #f4efe2;
    --po-paper-tint: #ece6d4;
    --po-pink: #ff3366;
    --po-ink: #0a1f4a;
    /* Pre-mixed overprint (pink * ink under multiply ~ this plum). */
    --po-plum: #4a1238;

    --po-display:
      "Big Shoulders Display", "Anton", "Oswald", "Impact",
      "Haettenschweiler", system-ui, sans-serif;
    --po-mono:
      "Space Mono", "IBM Plex Mono", ui-monospace, "SFMono-Regular", Menlo,
      monospace;

    /* Mis-registration offset. Lives in CSS so we can tweak across breakpoints
       (it should *not* scale with viewport — a 3px offset reads as a 3px
       offset whether mobile or desktop). 0 with reduced motion is wrong — the
       offset is part of the visual, not motion. */
    --po-shift-x: 3px;
    --po-shift-y: -2px;

    background: var(--po-paper);
    color: var(--po-ink);
    font-family: var(--po-mono);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;

    /* Paper texture: subtle noise + warm vignette. Cheap, all CSS. */
    background-image:
      /* faint pink fade in the corner — the "splotch" you get from the roller */
      radial-gradient(
        60% 50% at 0% 0%,
        rgba(255, 51, 102, 0.08) 0%,
        rgba(255, 51, 102, 0) 60%
      ),
      radial-gradient(
        70% 60% at 100% 100%,
        rgba(10, 31, 74, 0.06) 0%,
        rgba(10, 31, 74, 0) 70%
      );
    background-attachment: fixed;
  }

  /* Grain layer over everything. SVG turbulence for a film-grain / paper-stock
     feel. position:fixed so it doesn't bog down scrolling. */
  .po::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    opacity: 0.18;
    mix-blend-mode: multiply;
    background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='240' height='240'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.04 0 0 0 0 0.12 0 0 0 0 0.29 0 0 0 0.7 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 240px 240px;
  }

  .po ::selection {
    background: var(--po-pink);
    color: var(--po-paper);
  }

  .po a {
    color: inherit;
    text-decoration: none;
  }

  .po :focus-visible {
    outline: 3px solid var(--po-pink);
    outline-offset: 3px;
  }

  /* Display headings: condensed, heavy, tight. The hero owns its own type. */
  .po h1,
  .po h2,
  .po h3 {
    font-family: var(--po-display);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.01em;
    margin: 0;
    text-transform: uppercase;
  }

  /* The two-ink trick: any element marked `po-ink2` is rendered twice in
     stacked pseudos, each colored with one ink and offset by a few pixels.
     Both layers multiply against the paper so where they overlap you get
     plum. This works for text, blocks, anything with text content. */
  .po-ink2 {
    position: relative;
    isolation: isolate;
    color: transparent;
  }
  .po-ink2::before,
  .po-ink2::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: multiply;
    white-space: inherit;
    /* The pseudos inherit font-* automatically — they're pseudo-elements of
       the same box. */
  }
  .po-ink2::before {
    color: var(--po-ink);
    transform: translate(calc(var(--po-shift-x) * -1), calc(var(--po-shift-y) * -1));
    z-index: 1;
  }
  .po-ink2::after {
    color: var(--po-pink);
    transform: translate(var(--po-shift-x), var(--po-shift-y));
    z-index: 2;
  }

  /* Halftone block utility: stamp a CSS dot-grid on whatever element. Sized
     by --po-dot. Color via --po-dot-color. */
  .po-halftone {
    background-image: radial-gradient(
      var(--po-dot-color, var(--po-ink)) var(--po-dot-r, 22%),
      transparent calc(var(--po-dot-r, 22%) + 1%)
    );
    background-size: var(--po-dot, 8px) var(--po-dot, 8px);
  }

  .po-shell {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 40px);
  }

  /* Sections share a chunky stamp-style header. */
  .po-section {
    padding-block: clamp(40px, 6vw, 84px);
    position: relative;
  }

  .po-section + .po-section {
    border-top: 4px solid var(--po-ink);
  }

  .po-section__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: clamp(20px, 3vw, 32px);
    border-bottom: 2px dashed var(--po-ink);
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .po-section__title {
    font-size: clamp(40px, 8vw, 88px);
  }

  .po-section__num {
    font-family: var(--po-mono);
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--po-pink);
    text-transform: uppercase;
    transform: rotate(-1deg);
    transform-origin: top right;
  }

  /* Mono tag pills — used as venue tags, credits, etc. */
  .po-tag {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    font-family: var(--po-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border: 2px solid currentColor;
    background: var(--po-paper);
    line-height: 1;
    min-height: 22px;
  }

  @media (prefers-reduced-motion: reduce) {
    .po,
    .po *,
    .po *::before,
    .po *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
