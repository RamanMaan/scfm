---
interface Props {
  name: string;
}

const { name } = Astro.props;

const links = [
  { label: "Music", href: "#music" },
  { label: "Video", href: "#video" },
  { label: "Contact", href: "#contact" },
];
---

<nav class="px-nav" aria-label="Primary">
  <div class="px-nav__inner px-shell">
    <a class="px-nav__mark" href="#top">{name}</a>
    <ul class="px-nav__list">
      {
        links.map((link) => (
          <li>
            <a class="px-nav__link" href={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .px-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    color: var(--px-light);
    pointer-events: none;
  }

  .px-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: clamp(20px, 2vw, 28px);
    pointer-events: auto;
  }

  .px-nav__mark {
    color: currentColor;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .px-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(16px, 2.4vw, 28px);
  }

  .px-nav__link {
    color: currentColor;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  @media (max-width: 480px) {
    .px-nav__list {
      gap: 16px;
    }
  }
</style>
