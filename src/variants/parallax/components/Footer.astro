---
import type { CollectionEntry } from "astro:content";
import { orderedSocials, type SocialPlatform } from "../../../lib/socials";

interface Props {
  artist: CollectionEntry<"artist">;
}

const { artist } = Astro.props;
const socials = orderedSocials(artist.data.socials);

const ICON_PLATFORMS: ReadonlySet<SocialPlatform> = new Set([
  "spotify",
  "appleMusic",
  "youtube",
  "instagram",
]);

// TODO(steven): Sign up at https://web3forms.com, paste your access key into
// `.env` as `PUBLIC_WEB3FORMS_ACCESS_KEY`. Until then, the form will POST but
// Web3Forms will reject it with an "invalid access key" error.
const WEB3FORMS_ACCESS_KEY =
  import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ??
  "REPLACE_WITH_WEB3FORMS_ACCESS_KEY";
---

<footer class="px-section px-shell" id="contact">
  <header class="px-section__head">
    <h2 class="px-section__title">Contact</h2>
  </header>

  <form
    class="px-foot__form"
    action="https://api.web3forms.com/submit"
    method="POST"
    data-contact-form
  >
    <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
    <input
      type="hidden"
      name="subject"
      value={`${artist.data.name} \u2014 new contact form message`}
    />
    <input
      type="hidden"
      name="from_name"
      value="stevenchristopher.com contact form"
    />
    <label class="px-foot__honey" aria-hidden="true">
      Leave this field empty
      <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" />
    </label>

    <div class="px-foot__row">
      <label class="px-foot__field">
        <span class="px-foot__lbl">Name</span>
        <input type="text" name="name" autocomplete="name" required />
      </label>
      <label class="px-foot__field">
        <span class="px-foot__lbl">Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
    </div>

    <label class="px-foot__field">
      <span class="px-foot__lbl">Message</span>
      <textarea name="message" rows={4} required></textarea>
    </label>

    <div class="px-foot__formfoot">
      <p class="px-foot__status" data-contact-status aria-live="polite"></p>
      <button class="px-foot__submit" type="submit">Send</button>
    </div>
  </form>

  <p class="px-meta px-foot__follow">Or follow</p>
  <ul class="px-foot__socials">
    {
      socials.map(({ platform, url, label }) => (
        <li>
          <a
            class="px-foot__chip"
            href={url}
            target="_blank"
            rel="noopener"
            aria-label={label}
          >
            {ICON_PLATFORMS.has(platform) && (
              <>
                {platform === "spotify" && (
                  <svg
                    class="px-foot__icon"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                  </svg>
                )}
                {platform === "appleMusic" && (
                  <svg
                    class="px-foot__icon"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M23.994 6.124a9.23 9.23 0 00-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a5.022 5.022 0 00-1.877-.726 10.496 10.496 0 00-1.564-.15c-.04-.003-.083-.01-.124-.013H5.986c-.152.01-.303.017-.455.026-.747.043-1.49.123-2.193.4-1.336.53-2.3 1.452-2.865 2.78-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.801.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03a12.5 12.5 0 001.57-.1c.822-.106 1.596-.35 2.295-.81a5.046 5.046 0 001.88-2.207c.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.536a1.88 1.88 0 011.038-2.022c.323-.16.67-.25 1.018-.324.378-.082.758-.153 1.134-.24.274-.063.457-.23.51-.516a.904.904 0 00.02-.193c0-1.815 0-3.63-.002-5.443a.725.725 0 00-.026-.185c-.04-.15-.15-.243-.304-.234-.16.01-.318.035-.475.066-.76.15-1.52.303-2.28.456l-2.325.47-1.374.278c-.016.003-.032.01-.048.013-.277.077-.377.203-.39.49-.002.042 0 .086 0 .13-.002 2.602 0 5.204-.003 7.805 0 .42-.047.836-.215 1.227-.278.64-.77 1.04-1.434 1.233-.35.1-.71.16-1.075.172-.96.036-1.755-.6-1.92-1.544-.14-.812.23-1.685 1.154-2.075.357-.15.73-.232 1.108-.31.287-.06.575-.116.86-.177.383-.083.583-.323.6-.714v-.15c0-2.96 0-5.922.002-8.882 0-.123.013-.25.042-.37.07-.285.273-.448.546-.518.255-.066.515-.112.774-.165.733-.15 1.466-.296 2.2-.444l2.27-.46c.67-.134 1.34-.27 2.01-.403.22-.043.442-.088.663-.106.31-.025.523.17.554.482.008.073.012.148.012.223.002 1.91.002 3.822 0 5.732z" />
                  </svg>
                )}
                {platform === "youtube" && (
                  <svg
                    class="px-foot__icon"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                  </svg>
                )}
                {platform === "instagram" && (
                  <svg
                    class="px-foot__icon"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M7.0301.084c-1.2768.0602-2.1487.264-2.911.5634-.7888.3075-1.4575.72-2.1228 1.3877-.6652.6677-1.075 1.3368-1.3802 2.127-.2954.7638-.4956 1.6365-.552 2.914-.0564 1.2775-.0689 1.6882-.0626 4.947.0062 3.2586.0206 3.6671.0825 4.9473.061 1.2765.264 2.1482.5635 2.9107.308.7889.72 1.4573 1.388 2.1228.6679.6655 1.3365 1.0743 2.1285 1.38.7632.295 1.6361.4961 2.9134.552 1.2773.056 1.6884.069 4.9462.0627 3.2578-.0062 3.668-.0207 4.9478-.0814 1.28-.0607 2.147-.2652 2.9098-.5633.7889-.3086 1.4578-.72 2.1228-1.3881.665-.6682 1.0745-1.3378 1.3795-2.1284.2957-.7632.4966-1.636.552-2.9124.056-1.2809.0692-1.6898.063-4.948-.0063-3.2583-.021-3.6668-.0817-4.9465-.0607-1.2797-.264-2.1487-.5633-2.9117-.3084-.7889-.72-1.4568-1.3876-2.1228C21.2982 1.33 20.628.9208 19.8378.6165 19.074.321 18.2017.1197 16.9244.0645 15.6471.0093 15.236-.005 11.977.0014 8.718.0076 8.31.0215 7.0301.0839m.1402 21.6932c-1.17-.0509-1.8053-.2453-2.2287-.408-.5606-.216-.96-.4771-1.3819-.895-.422-.4178-.6811-.8186-.9-1.378-.1644-.4234-.3624-1.058-.4171-2.228-.0595-1.2645-.072-1.6442-.079-4.848-.007-3.2037.0053-3.583.0607-4.848.05-1.169.2456-1.805.408-2.2282.216-.5613.4762-.96.895-1.3816.4188-.4217.8184-.6814 1.3783-.9003.423-.1651 1.0575-.3614 2.227-.4171 1.2655-.06 1.6447-.072 4.848-.079 3.2033-.007 3.5835.005 4.8495.0608 1.169.0508 1.8053.2445 2.228.408.5608.216.96.4754 1.3816.895.4217.4194.6816.8176.9005 1.3787.1653.4217.3617 1.056.4169 2.2263.0602 1.2655.0739 1.645.0796 4.848.0058 3.203-.0055 3.5834-.061 4.848-.051 1.17-.245 1.8055-.408 2.2294-.216.5604-.4763.96-.8954 1.3814-.419.4215-.8181.6811-1.3783.9-.4224.1649-1.0577.3617-2.2262.4174-1.2656.0595-1.6448.072-4.8493.079-3.2045.007-3.5825-.006-4.848-.0608M16.953 5.5864A1.44 1.44 0 1 0 18.39 4.144a1.44 1.44 0 0 0-1.437 1.4424M5.8385 12.012c.0067 3.4032 2.7706 6.1557 6.173 6.1493 3.4026-.0065 6.157-2.7701 6.1506-6.1733-.0065-3.4032-2.771-6.1565-6.174-6.1498-3.403.0067-6.156 2.771-6.1496 6.1738M8 12.0077a4 4 0 1 1 4.008 3.9921A3.9996 3.9996 0 0 1 8 12.0077" />
                  </svg>
                )}
              </>
            )}
            <span>{label}</span>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="px-foot__base">
    <p class="px-meta">&copy; {artist.data.name}</p>
    <p class="px-meta">All rights reserved</p>
  </div>
</footer>

<style>
  .px-foot__form {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2vw, 22px);
    margin: 0 0 clamp(28px, 4vw, 44px);
  }

  .px-foot__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(14px, 2vw, 24px);
  }

  @media (max-width: 560px) {
    .px-foot__row {
      grid-template-columns: 1fr;
    }
  }

  .px-foot__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .px-foot__lbl {
    font-family: var(--px-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--px-muted);
  }

  .px-foot__field input,
  .px-foot__field textarea {
    appearance: none;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--px-rule);
    border-radius: 0;
    padding: 10px 0;
    font: inherit;
    font-size: 15px;
    color: var(--px-ink);
    width: 100%;
    min-height: 44px;
    transition: border-color 320ms var(--px-ease);
  }

  .px-foot__field textarea {
    min-height: 112px;
    resize: vertical;
    line-height: 1.55;
  }

  .px-foot__field input:focus,
  .px-foot__field textarea:focus {
    outline: none;
    border-bottom-color: var(--px-accent);
  }

  /* Honeypot — visually hidden but still focusable bait for bots. */
  .px-foot__honey {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .px-foot__formfoot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .px-foot__status {
    margin: 0;
    flex: 1 1 auto;
    font-size: 12px;
    letter-spacing: 0.02em;
    color: var(--px-muted);
    min-height: 1.4em;
  }

  .px-foot__submit {
    appearance: none;
    background: transparent;
    border: 1px solid var(--px-ink);
    color: var(--px-ink);
    padding: 12px 22px;
    font-family: var(--px-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    min-height: 44px;
    min-width: 120px;
    transition:
      background-color 320ms var(--px-ease),
      color 320ms var(--px-ease);
  }

  .px-foot__submit:hover:not(:disabled) {
    background: var(--px-ink);
    color: var(--px-bg);
  }

  .px-foot__submit:disabled {
    opacity: 0.5;
    cursor: progress;
  }

  .px-foot__follow {
    margin: 0 0 14px;
    padding-top: clamp(20px, 2.6vw, 28px);
    border-top: 1px solid var(--px-rule);
  }

  .px-foot__socials {
    list-style: none;
    margin: 0 0 clamp(28px, 4vw, 40px);
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .px-foot__chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border: 1px solid var(--px-rule);
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--px-ink);
    min-height: 44px;
    transition:
      border-color 320ms var(--px-ease),
      color 320ms var(--px-ease);
  }

  .px-foot__chip:hover {
    border-color: var(--px-accent);
    color: var(--px-accent);
  }

  .px-foot__icon {
    flex-shrink: 0;
    display: block;
    color: currentColor;
  }

  .px-foot__base {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: clamp(14px, 1.6vw, 22px);
    border-top: 1px solid var(--px-rule);
  }

  @media (max-width: 480px) {
    .px-foot__base {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const status = form?.querySelector<HTMLElement>("[data-contact-status]");
  const submit = form?.querySelector<HTMLButtonElement>(
    "button[type='submit']",
  );

  const setStatus = (message: string) => {
    if (status) status.textContent = message;
  };

  form?.addEventListener("submit", async (event) => {
    if (!submit) return;
    event.preventDefault();
    submit.disabled = true;
    setStatus("Sending\u2026");

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      if (!response.ok) {
        setStatus("Something went wrong. Try again.");
        return;
      }

      form.reset();
      setStatus("Thanks \u2014 I'll be in touch.");
    } catch {
      setStatus("Network error. Try again.");
    } finally {
      submit.disabled = false;
    }
  });
</script>
