---
import type { CollectionEntry } from "astro:content";
import { spotifyOpenUrl } from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

const primaryLink = (release: CollectionEntry<"releases">): string | null => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? null;
};

const formatLabel = (release: CollectionEntry<"releases">): string =>
  release.data.type === "single" ? "Single" : release.data.type.toUpperCase();
---

<section class="px-section px-shell" id="music">
  <header class="px-section__head">
    <h2 class="px-section__title">Music</h2>
  </header>

  <ol class="px-list">
    {
      releases.map((release, idx) => {
        const href = primaryLink(release);
        const num = String(idx + 1).padStart(2, "0");
        const format = formatLabel(release);
        const RowTag = href ? "a" : "div";

        return (
          <li class="px-list__item">
            <RowTag
              class:list={["px-list__row", !href && "px-list__row--static"]}
              {...(href ? { href, target: "_blank", rel: "noopener" } : {})}
            >
              <span class="px-list__num px-meta">{num}</span>
              <span class="px-list__title">{release.data.title}</span>
              <span class="px-list__meta px-meta">{format}</span>
              {href && (
                <span class="px-list__arrow" aria-hidden="true">
                  &rarr;
                </span>
              )}
            </RowTag>
          </li>
        );
      })
    }
  </ol>
</section>

<style>
  .px-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .px-list__item {
    border-top: 1px solid var(--px-rule);
  }

  .px-list__item:last-child {
    border-bottom: 1px solid var(--px-rule);
  }

  .px-list__row {
    display: grid;
    grid-template-columns: 40px 1fr auto 18px;
    gap: clamp(12px, 2.4vw, 32px);
    align-items: baseline;
    padding-block: clamp(14px, 1.8vw, 22px);
    color: var(--px-ink);
  }

  .px-list__title {
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 500;
    letter-spacing: -0.015em;
    transition: color 320ms var(--px-ease);
  }

  .px-list__meta {
    white-space: nowrap;
  }

  .px-list__arrow {
    font-size: 15px;
    color: var(--px-faint);
    text-align: right;
    transition:
      color 320ms var(--px-ease),
      transform 320ms var(--px-ease);
  }

  .px-list__row:hover .px-list__title,
  .px-list__row:hover .px-list__arrow {
    color: var(--px-accent);
  }

  .px-list__row:hover .px-list__arrow {
    transform: translateX(4px);
  }

  .px-list__row--static {
    cursor: default;
  }

  @media (max-width: 720px) {
    .px-list__row {
      grid-template-columns: 32px 1fr;
      gap: 10px;
    }

    .px-list__meta {
      grid-column: 2;
      padding-top: 2px;
    }

    .px-list__arrow {
      display: none;
    }
  }
</style>
