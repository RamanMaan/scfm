---
import type { CollectionEntry } from "astro:content";
import { orderedSocials } from "../../../lib/socials";

interface Props {
  artist: CollectionEntry<"artist">;
}

const { artist } = Astro.props;
const socials = orderedSocials(artist.data.socials);
---

<footer class="sy-foot sy-shell" id="contact">
  <p class="sy-eyebrow">Outro</p>

  <p class="sy-foot__locale">
    {artist.data.origin} &mdash; {artist.data.basedIn}
  </p>

  <ul class="sy-foot__list">
    {
      socials.map(({ label, url }) => (
        <li>
          <a class="sy-foot__link" href={url} target="_blank" rel="noopener">
            <span>{label}</span>
            <span class="sy-foot__arrow" aria-hidden="true">
              &rarr;
            </span>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="sy-foot__sig sy-eyebrow">
    &copy; {artist.data.name} &nbsp;&middot;&nbsp; All rights reserved
  </p>
</footer>

<style>
  .sy-foot {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 3vw, 32px);
    padding-block: clamp(48px, 8vw, 96px);
    border-top: 1px solid var(--sy-rule);
  }

  .sy-foot__locale {
    margin: 0;
    font-family: var(--sy-serif);
    font-size: clamp(20px, 3.2vw, 28px);
    font-style: italic;
    font-variation-settings:
      "wght" 320,
      "opsz" 36;
    color: var(--sy-ink-dim);
    letter-spacing: -0.01em;
  }

  .sy-foot__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid var(--sy-rule);
    border-bottom: 1px solid var(--sy-rule);
    padding-block: 12px;
  }

  .sy-foot__link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-block: 14px;
    min-height: 44px;
    font-family: var(--sy-serif);
    font-size: clamp(20px, 3vw, 26px);
    font-variation-settings:
      "wght" 360,
      "opsz" 36;
    letter-spacing: -0.015em;
    color: var(--sy-ink);
    transition:
      color 320ms,
      font-variation-settings 320ms;
  }

  .sy-foot__arrow {
    font-size: 18px;
    color: var(--sy-ink-faint);
    transition:
      color 320ms,
      transform 320ms;
  }

  .sy-foot__link:hover {
    color: hsl(var(--sy-hue) 95% 80%);
    font-variation-settings:
      "wght" 500,
      "opsz" 48;
  }

  .sy-foot__link:hover .sy-foot__arrow {
    color: hsl(var(--sy-hue) 95% 80%);
    transform: translateX(6px);
  }

  .sy-foot__sig {
    margin: 0;
  }
</style>
