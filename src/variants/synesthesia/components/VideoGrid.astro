---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  videos: CollectionEntry<"videos">[];
  channelUrl: string;
}

const { videos, channelUrl } = Astro.props;

const watchUrl = (video: CollectionEntry<"videos">): string => {
  if (video.data.youtubeUrl) return video.data.youtubeUrl;
  if (video.data.youtubeId) {
    return `https://www.youtube.com/watch?v=${video.data.youtubeId}`;
  }
  return channelUrl;
};

const thumb = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<section class="sy-vid sy-shell" id="video">
  <header class="sy-vid__head">
    <p class="sy-eyebrow">Companion / video</p>
    <h2 class="sy-vid__title">Watch</h2>
  </header>

  {
    videos.length > 0 ? (
      <ul class="sy-vid__list">
        {videos.map((video) => {
          const id = video.data.youtubeId;
          return (
            <li class="sy-vid__item">
              <a
                class="sy-vid__card"
                href={watchUrl(video)}
                target="_blank"
                rel="noopener"
              >
                <span class="sy-vid__media" aria-hidden="true">
                  {id ? (
                    <Image
                      src={thumb(id)}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      width={480}
                      height={360}
                      widths={[240, 480, 720]}
                      sizes="(min-width: 720px) 380px, 100vw"
                    />
                  ) : (
                    <span class="sy-vid__placeholder" />
                  )}
                </span>
                <span class="sy-vid__body">
                  <span class="sy-vid__name">{video.data.title}</span>
                  <span class="sy-eyebrow sy-vid__cue">Watch &rarr;</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="sy-vid__empty">
        <a href={channelUrl} target="_blank" rel="noopener">
          <span>Visit the channel</span> <span aria-hidden="true">&rarr;</span>
        </a>
      </p>
    )
  }
</section>

<style>
  .sy-vid {
    padding-block: clamp(48px, 8vw, 96px);
  }

  .sy-vid__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: clamp(28px, 4vw, 44px);
  }

  .sy-vid__title {
    margin: 0;
    font-family: var(--sy-serif);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400;
    font-variation-settings:
      "wght" 320,
      "opsz" 80;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--sy-ink);
  }

  .sy-vid__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: clamp(20px, 3vw, 32px);
  }

  .sy-vid__card {
    display: grid;
    grid-template-rows: auto auto;
    gap: 14px;
    color: var(--sy-ink);
  }

  .sy-vid__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.04);
    isolation: isolate;
  }

  .sy-vid__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.7) contrast(1.05)
      hue-rotate(calc((var(--sy-hue) - 268) * 1deg));
    transition: filter 600ms;
  }

  .sy-vid__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      hsl(var(--sy-hue) 60% 28% / 0.6),
      hsl(calc(var(--sy-hue) + 140) 60% 22% / 0.4)
    );
  }

  .sy-vid__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sy-vid__name {
    font-family: var(--sy-serif);
    font-size: clamp(18px, 2.4vw, 22px);
    font-weight: 400;
    font-variation-settings:
      "wght" 380,
      "opsz" 24;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--sy-ink);
    transition: color 320ms;
  }

  .sy-vid__cue {
    color: var(--sy-ink-faint);
  }

  .sy-vid__card:hover .sy-vid__name {
    color: hsl(var(--sy-hue) 95% 82%);
  }

  .sy-vid__empty {
    margin: 0;
    font-family: var(--sy-serif);
    font-size: 18px;
  }

  .sy-vid__empty a {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
  }
</style>
