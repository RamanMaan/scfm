---
import type { CollectionEntry } from "astro:content";
import {
  SPOTIFY_EMBED_HEIGHT,
  getSpotifyEmbedUrl,
  spotifyOpenUrl,
} from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

const fmtYear = (d: Date) => d.getUTCFullYear();
const fmtTypeLabel = (t: CollectionEntry<"releases">["data"]["type"]) =>
  t === "single" ? "Single" : t.toUpperCase();
---

<section class="sy-rel sy-shell" id="music">
  <header class="sy-rel__head">
    <p class="sy-eyebrow">Side B / releases</p>
    <h2 class="sy-rel__title">Recent</h2>
  </header>

  <ol class="sy-rel__list">
    {
      releases.map((release, idx) => {
        const { data } = release;
        const num = String(idx + 1).padStart(2, "0");
        const hasEmbed = Boolean(data.spotifyId);
        const detailsId = `sy-rel-${release.id}`;
        const fallbackHref = data.spotifyId
          ? spotifyOpenUrl(data.spotifyType, data.spotifyId)
          : data.appleMusicUrl;
        return (
          <li class="sy-rel__item">
            <details class="sy-rel__details" name="sy-release">
              <summary class="sy-rel__row" aria-controls={detailsId}>
                <span class="sy-eyebrow sy-rel__num">{num}</span>
                <span class="sy-rel__name">
                  <span class="sy-rel__name-text">{data.title}</span>
                  {data.featuring.length > 0 && (
                    <span class="sy-rel__feat">
                      with {data.featuring.join(", ")}
                    </span>
                  )}
                </span>
                <span class="sy-rel__meta sy-eyebrow">
                  {fmtTypeLabel(data.type)}{" "}
                  <span class="sy-rel__year">
                    &middot; {fmtYear(data.releaseDate)}
                  </span>
                </span>
                <span class="sy-rel__cue" aria-hidden="true">
                  <span class="sy-rel__cue-open">Listen</span>
                  <span class="sy-rel__cue-close">Close</span>
                </span>
              </summary>

              <div class="sy-rel__body" id={detailsId}>
                {hasEmbed && data.spotifyId ? (
                  <div
                    class="sy-rel__embed"
                    data-embed
                    data-embed-src={getSpotifyEmbedUrl({
                      type: data.spotifyType,
                      id: data.spotifyId,
                    })}
                    style={`min-height:${SPOTIFY_EMBED_HEIGHT.compact}px`}
                  />
                ) : (
                  <p class="sy-rel__missing">
                    {fallbackHref ? (
                      <a href={fallbackHref} target="_blank" rel="noopener">
                        Open on{" "}
                        {data.spotifyId ? "Spotify" : "Apple Music"}{" "}
                        &rarr;
                      </a>
                    ) : (
                      "Stream link pending."
                    )}
                  </p>
                )}
                {data.appleMusicUrl && (
                  <p class="sy-rel__alt">
                    <a
                      href={data.appleMusicUrl}
                      target="_blank"
                      rel="noopener"
                    >
                      Also on Apple Music &rarr;
                    </a>
                  </p>
                )}
                {data.description && (
                  <p class="sy-rel__desc">{data.description}</p>
                )}
              </div>
            </details>
          </li>
        );
      })
    }
  </ol>
</section>

<script>
  /**
   * Lazy-load Spotify iframes: only inject the <iframe> when the parent
   * <details> is opened. Keeps the silent-state page weightless.
   */
  const blocks = document.querySelectorAll<HTMLElement>("[data-embed]");
  blocks.forEach((block) => {
    const details = block.closest("details");
    if (!details) return;
    let loaded = false;
    details.addEventListener("toggle", () => {
      if (!details.open || loaded) return;
      loaded = true;
      const src = block.dataset.embedSrc;
      if (!src) return;
      const frame = document.createElement("iframe");
      frame.src = src;
      frame.width = "100%";
      frame.height = "152";
      frame.allow = "encrypted-media; clipboard-write";
      frame.loading = "lazy";
      frame.title = "Spotify player";
      block.appendChild(frame);
    });
  });
</script>

<style>
  .sy-rel {
    padding-block: clamp(48px, 8vw, 96px);
  }

  .sy-rel__head {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: clamp(28px, 4vw, 44px);
  }

  .sy-rel__title {
    margin: 0;
    font-family: var(--sy-serif);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 400;
    font-variation-settings:
      "wght" 320,
      "opsz" 80;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--sy-ink);
  }

  .sy-rel__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sy-rel__item {
    border-top: 1px solid var(--sy-rule);
  }
  .sy-rel__item:last-child {
    border-bottom: 1px solid var(--sy-rule);
  }

  .sy-rel__details {
    width: 100%;
  }

  .sy-rel__row {
    display: grid;
    grid-template-columns: 36px 1fr auto auto;
    gap: clamp(12px, 2.4vw, 24px);
    align-items: baseline;
    padding-block: clamp(16px, 2vw, 24px);
    cursor: pointer;
    list-style: none;
    min-height: 48px;
  }

  .sy-rel__row::-webkit-details-marker {
    display: none;
  }

  .sy-rel__name {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .sy-rel__name-text {
    font-family: var(--sy-serif);
    font-size: clamp(20px, 3vw, 30px);
    font-weight: 400;
    font-variation-settings:
      "wght" 380,
      "opsz" 36;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--sy-ink);
    transition:
      color 320ms,
      font-variation-settings 320ms;
  }

  .sy-rel__feat {
    font-family: var(--sy-sans);
    font-size: 12px;
    color: var(--sy-ink-faint);
    letter-spacing: 0.05em;
  }

  .sy-rel__meta {
    white-space: nowrap;
    align-self: baseline;
  }

  .sy-rel__year {
    color: var(--sy-ink-faint);
  }

  .sy-rel__cue {
    font-family: var(--sy-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sy-ink-dim);
    position: relative;
    text-align: right;
    min-width: 56px;
  }

  .sy-rel__cue-close {
    display: none;
  }

  .sy-rel__details[open] .sy-rel__cue-open {
    display: none;
  }

  .sy-rel__details[open] .sy-rel__cue-close {
    display: inline;
  }

  .sy-rel__row:hover .sy-rel__name-text,
  .sy-rel__details[open] .sy-rel__name-text {
    font-variation-settings:
      "wght" 540,
      "opsz" 48;
    color: hsl(var(--sy-hue) 95% 82%);
  }

  .sy-rel__body {
    padding-block: 12px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .sy-rel__embed {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
  }

  .sy-rel__embed iframe {
    display: block;
    border: 0;
    width: 100%;
  }

  .sy-rel__alt,
  .sy-rel__missing,
  .sy-rel__desc {
    margin: 0;
    font-family: var(--sy-sans);
    font-size: 13px;
    color: var(--sy-ink-dim);
    letter-spacing: 0.01em;
  }

  .sy-rel__desc {
    font-family: var(--sy-serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    max-width: 56ch;
  }

  @media (max-width: 560px) {
    .sy-rel__row {
      grid-template-columns: 28px 1fr auto;
      gap: 12px;
    }
    .sy-rel__meta {
      grid-column: 2 / 4;
      padding-top: 2px;
    }
    .sy-rel__cue {
      grid-row: 1;
      grid-column: 3;
      align-self: baseline;
      min-width: auto;
    }
  }
</style>
