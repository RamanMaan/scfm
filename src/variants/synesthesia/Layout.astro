---
// Fraunces Variable is the monumental serif whose weight + optical-size axes
// are driven by the live audio analyser. Inter Tight Variable is the
// minimal label/metadata face (already in node_modules from `parallax`).
//
// Fraunces Variable needs `pnpm add @fontsource-variable/fraunces` — see
// REGISTRATION.md.
import "@fontsource-variable/fraunces/index.css";
import "@fontsource-variable/inter-tight/wght.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="sy"
>
  <slot />
</BaseHtml>

<style is:global>
  .sy {
    /* Live-driven CSS variables. JS only mutates these — no layout thrash.
       --sy-hue: 0..360,  --sy-energy: 0..1,  --sy-weight: 100..900,
       --sy-opsz: 9..144, --sy-grain: 0..1. */
    --sy-hue: 268;
    --sy-energy: 0;
    --sy-weight: 240;
    --sy-opsz: 144;
    --sy-grain: 0.18;

    --sy-ink: #f4ecde;
    --sy-ink-dim: rgba(244, 236, 222, 0.6);
    --sy-ink-faint: rgba(244, 236, 222, 0.32);
    --sy-rule: rgba(244, 236, 222, 0.14);

    --sy-serif:
      "Fraunces Variable", "Fraunces", "Times New Roman", Times, serif;
    --sy-sans:
      "Inter Tight Variable", "Inter Tight", system-ui, -apple-system,
      "Segoe UI", sans-serif;

    /* The page itself is the canvas. A single deep-violet base sits beneath
       three radial pools whose hue follows the analyser via --sy-hue. */
    background-color: #0a0710;
    background-image:
      radial-gradient(
        80vmax 60vmax at 18% 22%,
        hsl(var(--sy-hue) 78% 38% / 0.55) 0%,
        hsl(var(--sy-hue) 78% 38% / 0) 60%
      ),
      radial-gradient(
        70vmax 70vmax at 82% 78%,
        hsl(calc(var(--sy-hue) + 140) 70% 42% / 0.42) 0%,
        hsl(calc(var(--sy-hue) + 140) 70% 42% / 0) 65%
      ),
      radial-gradient(
        50vmax 50vmax at 50% 110%,
        hsl(calc(var(--sy-hue) + 220) 60% 32% / 0.5) 0%,
        hsl(calc(var(--sy-hue) + 220) 60% 32% / 0) 70%
      );
    background-attachment: fixed;
    color: var(--sy-ink);
    font-family: var(--sy-sans);
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0.01em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    min-height: 100dvh;
    overflow-x: hidden;
  }

  /* Background drift: slow color migration even when audio is idle, so the
     page is never a flat color. JS overrides --sy-hue once playback begins. */
  @keyframes sy-hue-drift {
    0% {
      --sy-hue: 268;
    }
    25% {
      --sy-hue: 312;
    }
    50% {
      --sy-hue: 18;
    }
    75% {
      --sy-hue: 196;
    }
    100% {
      --sy-hue: 268;
    }
  }

  @property --sy-hue {
    syntax: "<number>";
    inherits: true;
    initial-value: 268;
  }

  .sy:not(.sy--live) {
    animation: sy-hue-drift 90s linear infinite;
  }

  /* Grain overlay — SVG turbulence rendered to data URI. Density (opacity)
     follows --sy-grain. position:fixed so it never causes scroll repaint. */
  .sy::before {
    content: "";
    position: fixed;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml;utf8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22320%22%20height%3D%22320%22%3E%3Cfilter%20id%3D%22n%22%3E%3CfeTurbulence%20type%3D%22fractalNoise%22%20baseFrequency%3D%220.9%22%20numOctaves%3D%222%22%20stitchTiles%3D%22stitch%22%2F%3E%3CfeColorMatrix%20values%3D%220%200%200%200%201%200%200%200%200%201%200%200%200%200%201%200%200%200%200.6%200%22%2F%3E%3C%2Ffilter%3E%3Crect%20width%3D%22100%25%22%20height%3D%22100%25%22%20filter%3D%22url(%23n)%22%2F%3E%3C%2Fsvg%3E");
    background-size: 320px 320px;
    opacity: var(--sy-grain);
    mix-blend-mode: overlay;
    will-change: opacity;
  }

  /* Second, slower grain layer for analog warmth — chroma noise behind. */
  .sy::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 120% 80% at 50% 50%,
        transparent 40%,
        rgba(0, 0, 0, 0.55) 100%
      );
  }

  .sy > * {
    position: relative;
    z-index: 1;
  }

  .sy ::selection {
    background: hsl(var(--sy-hue) 90% 60% / 0.8);
    color: #0a0710;
  }

  .sy a {
    color: inherit;
    text-decoration: none;
    transition: color 360ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  .sy a:hover {
    color: hsl(var(--sy-hue) 95% 78%);
  }

  .sy :focus-visible {
    outline: 1px solid hsl(var(--sy-hue) 95% 78%);
    outline-offset: 4px;
  }

  .sy-shell {
    width: 100%;
    max-width: 920px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 40px);
  }

  .sy-eyebrow {
    font-family: var(--sy-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--sy-ink-faint);
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .sy,
    .sy *,
    .sy *::before,
    .sy *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
