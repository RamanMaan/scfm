---
import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="brut"
>
  <slot />
</BaseHtml>

<style is:global>
  .brut {
    --br-bg: #ffffff;
    --br-ink: #000000;
    --br-accent: #ff2400;
    --br-muted: #6b6b6b;
    --br-rule: 2px;
    --br-mono:
      ui-monospace, "SFMono-Regular", "Menlo", "Cascadia Mono", "Consolas",
      monospace;

    background: var(--br-bg);
    color: var(--br-ink);
    font-family: var(--br-mono);
    font-size: 14px;
    line-height: 1.45;
    -webkit-font-smoothing: subpixel-antialiased;
  }

  .brut * {
    border-radius: 0 !important;
  }

  .brut ::selection {
    background: var(--br-accent);
    color: var(--br-bg);
  }

  .brut a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .brut a:hover {
    background: var(--br-ink);
    color: var(--br-bg);
    text-decoration: none;
  }

  .brut h1,
  .brut h2,
  .brut h3 {
    font-family: var(--br-mono);
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .brut :focus-visible {
    outline: 2px solid var(--br-accent);
    outline-offset: 2px;
  }

  .brut .br-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    border-bottom: var(--br-rule) solid var(--br-ink);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .brut .br-section {
    border-bottom: var(--br-rule) solid var(--br-ink);
    padding: 32px 16px;
  }

  .brut .br-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }

  .brut .br-eyebrow {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin: 0 0 16px;
  }

  .brut iframe {
    border: var(--br-rule) solid var(--br-ink) !important;
  }
</style>
