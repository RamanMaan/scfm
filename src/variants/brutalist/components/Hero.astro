---
import { Picture } from "astro:assets";
import heroImage from "../../../assets/HeroImage.jpg";

interface Props {
  name: string;
}

const { name } = Astro.props;

const today = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(new Date());

const segments = name.toUpperCase().split(" ");
const fileSlug = `${segments[0]}.${(segments[1] ?? "PROFILE").slice(0, 3)}`;
---

<header class="br-hero" id="top">
  <nav class="br-bar" aria-label="Primary">
    <span>FILE: ARTIST/{fileSlug}</span>
    <ul class="br-bar__nav">
      <li><a href="#music">MUSIC</a></li>
      <li><a href="#video">VIDEO</a></li>
      <li><a href="#contact">CONTACT</a></li>
    </ul>
    <span class="br-bar__edition">EDITION 01 / {today}</span>
  </nav>

  <figure class="br-hero__figure" aria-label={`${name} — studio portrait`}>
    <Picture
      class="br-hero__still"
      src={heroImage}
      alt={`Portrait of ${name}`}
      widths={[640, 1080, 1600, 2400]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={78}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>

  <h1 class="br-hero__title" aria-label={name}>
    {segments.map((segment) => <span class="br-hero__word">{segment}</span>)}
  </h1>
</header>

<style>
  .br-hero {
    border-bottom: var(--br-rule) solid var(--br-ink);
  }

  .br-bar__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 16px;
  }

  .br-bar__edition {
    display: none;
  }

  @media (min-width: 720px) {
    .br-bar__edition {
      display: inline;
    }
  }

  .br-hero__figure {
    margin: 0;
    border-bottom: var(--br-rule) solid var(--br-ink);
    background: var(--br-bg);
    overflow: hidden;
  }

  .br-hero__still {
    display: block;
    width: 100%;
    height: clamp(60vh, 78vw, 88vh);
    max-height: 880px;
    object-fit: cover;
    filter: grayscale(1) contrast(1.08);
  }

  .br-hero__title {
    display: block;
    padding: 16px;
    font-size: clamp(56px, 16vw, 220px);
    line-height: 0.85;
    margin: 0;
    word-break: break-word;
  }

  .br-hero__word {
    display: block;
  }

  .br-hero__word:nth-child(even) {
    text-align: right;
  }
</style>
