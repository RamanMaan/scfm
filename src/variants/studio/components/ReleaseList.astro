---
import type { CollectionEntry } from "astro:content";
import { spotifyOpenUrl } from "../../../lib/spotify";

interface Props {
  releases: CollectionEntry<"releases">[];
}

const { releases } = Astro.props;

const primaryLink = (release: CollectionEntry<"releases">): string | null => {
  if (release.data.spotifyId) {
    return spotifyOpenUrl(release.data.spotifyType, release.data.spotifyId);
  }
  return release.data.appleMusicUrl ?? null;
};

const formatLabel = (release: CollectionEntry<"releases">): string =>
  release.data.type === "single" ? "Single" : release.data.type.toUpperCase();
---

<section class="st-section st-section--ruled st-shell" id="music">
  <header class="st-index__head">
    <h2 class="st-index__title">Music</h2>
    <span class="st-meta">{String(releases.length).padStart(2, "0")}</span>
  </header>

  <ol class="st-list">
    {
      releases.map((release, idx) => {
        const href = primaryLink(release);
        const num = String(idx + 1).padStart(2, "0");
        const format = formatLabel(release);
        const RowTag = href ? "a" : "div";

        return (
          <li class="st-list__item">
            <RowTag
              class:list={["st-list__row", !href && "st-list__row--static"]}
              {...(href ? { href, target: "_blank", rel: "noopener" } : {})}
            >
              <span class="st-list__num st-meta">{num}</span>
              <span class="st-list__title">{release.data.title}</span>
              <span class="st-list__meta st-meta">{format}</span>
              {href && (
                <span class="st-list__arrow" aria-hidden="true">
                  &rarr;
                </span>
              )}
            </RowTag>
          </li>
        );
      })
    }
  </ol>
</section>

<style>
  .st-index__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: clamp(40px, 4vw, 64px);
  }

  .st-index__title {
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .st-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .st-list__item {
    border-top: 1px solid var(--st-rule);
  }

  .st-list__item:last-child {
    border-bottom: 1px solid var(--st-rule);
  }

  .st-list__row {
    display: grid;
    grid-template-columns: 56px 1fr auto 20px;
    gap: clamp(16px, 3vw, 48px);
    align-items: baseline;
    padding-block: clamp(22px, 2.6vw, 34px);
    color: var(--st-ink);
  }

  .st-list__title {
    font-size: clamp(22px, 2.6vw, 36px);
    font-weight: 500;
    letter-spacing: -0.015em;
    transition: color 320ms var(--st-ease);
  }

  .st-list__meta {
    white-space: nowrap;
  }

  .st-list__arrow {
    font-size: 16px;
    color: var(--st-faint);
    text-align: right;
    transition:
      color 320ms var(--st-ease),
      transform 320ms var(--st-ease);
  }

  .st-list__row:hover .st-list__title,
  .st-list__row:hover .st-list__arrow {
    color: var(--st-accent);
  }

  .st-list__row:hover .st-list__arrow {
    transform: translateX(4px);
  }

  .st-list__row--static {
    cursor: default;
  }

  @media (max-width: 720px) {
    .st-list__row {
      grid-template-columns: 40px 1fr;
      gap: 12px;
    }

    .st-list__meta {
      grid-column: 2;
      padding-top: 4px;
    }

    .st-list__arrow {
      display: none;
    }
  }
</style>
