---
import { Picture } from "astro:assets";
import heroImage from "../../../assets/HeroImage.jpg";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<header class="st-hero" id="top">
  <figure class="st-hero__figure" aria-label={`${name} — studio portrait`}>
    <Picture
      class="st-hero__still"
      src={heroImage}
      alt={`Portrait of ${name}`}
      widths={[640, 1080, 1600, 2400]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={78}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>
</header>

<style>
  .st-hero {
    position: relative;
  }

  .st-hero__figure {
    margin: 0;
    background: #f5f5f4;
    overflow: hidden;
  }

  .st-hero__still {
    display: block;
    width: 100%;
    height: clamp(58vh, 80vw, 88vh);
    max-height: 920px;
    object-fit: cover;
    filter: grayscale(1);
  }

  @supports (animation-timeline: scroll()) {
    .st-hero__still {
      filter: grayscale(0);
      animation: st-hero-desaturate linear both;
      animation-timeline: scroll(root);
      animation-range: 0 50dvh;
      will-change: filter;
    }
  }

  @keyframes st-hero-desaturate {
    from {
      filter: grayscale(0);
    }
    to {
      filter: grayscale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .st-hero__still {
      animation: none;
      filter: grayscale(1);
    }
  }

  .st-hero__caption {
    display: flex;
    align-items: baseline;
    gap: 16px;
    padding-top: clamp(20px, 2vw, 28px);
  }

  .st-hero__name {
    margin: 0;
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--st-ink);
  }
</style>
