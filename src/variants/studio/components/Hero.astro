---
import { Picture } from "astro:assets";
import heroImage from "../../../assets/HeroImage.jpg";

interface Props {
  name: string;
}

const { name } = Astro.props;
---

<header class="st-hero" id="top">
  <figure class="st-hero__figure" aria-label={`${name} — studio portrait`}>
    <Picture
      class="st-hero__still"
      src={heroImage}
      alt={`Portrait of ${name}`}
      widths={[640, 1080, 1600, 2400]}
      sizes="100vw"
      formats={["avif", "webp"]}
      quality={78}
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </figure>

  <div class="st-hero__caption st-shell">
    <p class="st-hero__name">{name}</p>
    <p class="st-meta st-hero__plate">Plate 01</p>
  </div>
</header>

<style>
  .st-hero {
    position: relative;
  }

  .st-hero__figure {
    margin: 0;
    background: #f5f5f4;
    overflow: hidden;
  }

  .st-hero__still {
    display: block;
    width: 100%;
    height: clamp(58vh, 80vw, 88vh);
    max-height: 920px;
    object-fit: cover;
    filter: grayscale(1);
  }

  .st-hero__caption {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: clamp(20px, 2vw, 28px);
  }

  .st-hero__name {
    margin: 0;
    font-size: clamp(20px, 2vw, 26px);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--st-ink);
  }

  .st-hero__plate {
    margin: 0;
  }
</style>
