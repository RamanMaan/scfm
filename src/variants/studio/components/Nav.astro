---
interface Props {
  name: string;
}

const { name } = Astro.props;

const links = [
  { label: "Music", href: "#music" },
  { label: "Video", href: "#video" },
  { label: "Contact", href: "#contact" },
];
---

<nav class="st-nav st-shell" aria-label="Primary">
  <a class="st-nav__mark" href="#top">{name}</a>
  <ul class="st-nav__list">
    {
      links.map((link) => (
        <li>
          <a class="st-nav__link" href={link.href}>
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .st-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-block: clamp(20px, 2vw, 28px);
  }

  .st-nav__mark {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--st-ink);
  }

  .st-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: clamp(16px, 2.4vw, 28px);
  }

  .st-nav__link {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--st-ink);
  }

  @media (max-width: 480px) {
    .st-nav__list {
      gap: 16px;
    }
  }
</style>
