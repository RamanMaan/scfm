---
import "@fontsource-variable/inter-tight/wght.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="st"
>
  <slot />
</BaseHtml>

<style is:global>
  .st {
    --st-bg: #ffffff;
    --st-ink: #0a0a0a;
    --st-muted: #6f6f6f;
    --st-faint: #c8c8c8;
    --st-rule: rgba(10, 10, 10, 0.08);
    /* Faded steel blue. Reserved for selection + focus; no headline color. */
    --st-accent: #5f7a90;
    --st-sans:
      "Inter Tight Variable", "Inter Tight", system-ui, -apple-system,
      "Segoe UI", "Helvetica Neue", sans-serif;
    --st-ease: cubic-bezier(0.22, 0.61, 0.36, 1);

    background: var(--st-bg);
    color: var(--st-ink);
    font-family: var(--st-sans);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0.005em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .st ::selection {
    background: var(--st-accent);
    color: var(--st-bg);
  }

  .st a {
    color: inherit;
    text-decoration: none;
    transition: color 320ms var(--st-ease);
  }

  .st a:hover {
    color: var(--st-accent);
  }

  .st h1,
  .st h2,
  .st h3 {
    font-family: var(--st-sans);
    font-weight: 500;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .st :focus-visible {
    outline: 1px solid var(--st-accent);
    outline-offset: 4px;
  }

  .st .st-shell {
    width: 100%;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 56px);
  }

  .st .st-section {
    padding-block: clamp(96px, 14vw, 192px);
  }

  .st .st-section--ruled {
    border-top: 1px solid var(--st-rule);
  }

  .st .st-meta {
    font-family: var(--st-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--st-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (prefers-reduced-motion: reduce) {
    .st,
    .st *,
    .st *::before,
    .st *::after {
      transition-duration: 0.001ms !important;
      animation-duration: 0.001ms !important;
    }
  }
</style>
