---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  videos: CollectionEntry<"videos">[];
  channelUrl: string;
}

const { videos, channelUrl } = Astro.props;

// PLACEHOLDER LYRIC — line iii.
const LINE = "Some of them got pictures,";

const watchUrl = (video: CollectionEntry<"videos">): string => {
  if (video.data.youtubeUrl) return video.data.youtubeUrl;
  if (video.data.youtubeId) {
    return `https://www.youtube.com/watch?v=${video.data.youtubeId}`;
  }
  return channelUrl;
};

const thumbHi = (id: string) => `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
const thumbLo = (id: string) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---

<section class="vs-section vs-shell" id="video">
  <header class="vs-section__head">
    <p class="vs-tag">Verse — iii. the picture of it</p>
    <h2 class="vs-line">{LINE}</h2>
  </header>

  {
    videos.length > 0 ? (
      <ul class="vs-vid">
        {videos.map((video) => {
          const id = video.data.youtubeId;
          return (
            <li class="vs-vid__item">
              <a
                class="vs-vid__card"
                href={watchUrl(video)}
                target="_blank"
                rel="noopener"
              >
                <span class="vs-vid__media" aria-hidden="true">
                  {id ? (
                    <Image
                      src={thumbHi(id)}
                      data-fallback={thumbLo(id)}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      width={1280}
                      height={720}
                    />
                  ) : (
                    <span class="vs-vid__placeholder" />
                  )}
                  <span class="vs-vid__scrim" aria-hidden="true" />
                  <span class="vs-vid__play" aria-hidden="true">&#9655;</span>
                </span>
                <span class="vs-vid__cap">
                  <span class="vs-vid__title">{video.data.title}</span>
                  <span class="vs-vid__arrow" aria-hidden="true">&rarr;</span>
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    ) : (
      <p class="vs-vid__empty">
        <a href={channelUrl} target="_blank" rel="noopener">
          Visit the channel <span aria-hidden="true">&rarr;</span>
        </a>
      </p>
    )
  }
</section>

<script>
  const imgs = document.querySelectorAll<HTMLImageElement>(
    ".vs-vid__media img[data-fallback]",
  );
  imgs.forEach((img) => {
    const handleError = () => {
      const fallback = img.dataset.fallback;
      if (!fallback || img.src === fallback) return;
      img.removeAttribute("srcset");
      img.src = fallback;
    };
    img.addEventListener("error", handleError, { once: true });
  });
</script>

<style>
  .vs-vid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vh, 36px);
  }

  @media (min-width: 720px) {
    .vs-vid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .vs-vid__item {
    margin: 0;
  }

  .vs-vid__card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: var(--vs-bone);
  }

  .vs-vid__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--vs-ink-soft);
    border: 1px solid var(--vs-rule);
    isolation: isolate;
  }

  .vs-vid__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.85) contrast(1.02) brightness(0.92);
    transition:
      filter 600ms var(--vs-ease),
      transform 800ms var(--vs-ease);
  }

  .vs-vid__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(233, 227, 211, 0.06),
      rgba(233, 227, 211, 0.02)
    );
  }

  .vs-vid__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(12, 13, 18, 0.1) 0%,
      rgba(12, 13, 18, 0.45) 100%
    );
    pointer-events: none;
  }

  .vs-vid__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 44px;
    color: var(--vs-bone);
    opacity: 0.85;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
    pointer-events: none;
    transition:
      opacity 380ms var(--vs-ease),
      transform 380ms var(--vs-ease);
  }

  .vs-vid__card:hover .vs-vid__media img {
    filter: saturate(1) contrast(1.04) brightness(1);
    transform: scale(1.02);
  }

  .vs-vid__card:hover .vs-vid__play {
    opacity: 1;
    transform: scale(1.06);
  }

  .vs-vid__cap {
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-height: 44px;
  }

  .vs-vid__title {
    flex: 1 1 auto;
    font-family: var(--vs-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 2.2vw, 22px);
    letter-spacing: -0.005em;
    color: var(--vs-bone);
    text-wrap: balance;
  }

  .vs-vid__arrow {
    color: var(--vs-accent);
    font-size: 16px;
    transition: transform 380ms var(--vs-ease);
  }

  .vs-vid__card:hover .vs-vid__arrow {
    transform: translateX(4px);
  }

  .vs-vid__empty {
    margin: 0;
    font-family: var(--vs-serif);
    font-style: italic;
    font-size: clamp(18px, 2vw, 22px);
  }

  @media (prefers-reduced-motion: reduce) {
    .vs-vid__media img,
    .vs-vid__play,
    .vs-vid__arrow {
      transition: none;
    }
    .vs-vid__card:hover .vs-vid__media img {
      transform: none;
    }
  }
</style>
