---
import "@fontsource/ibm-plex-serif/400.css";
import "@fontsource/ibm-plex-serif/400-italic.css";
import "@fontsource/ibm-plex-serif/500.css";

import BaseHtml from "../../layouts/BaseHtml.astro";
import meta from "./meta";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseHtml
  title={title}
  description={description}
  ogImage={meta.ogImage}
  ogImageAlt={meta.ogImageAlt}
  bodyClass="vs"
>
  <slot />
</BaseHtml>

<style is:global>
  .vs {
    /* Midnight ink ground — the opposite temperament of studio's bright paper.
       Dominant ink, warm bone for type, one bruised-lilac accent. */
    --vs-ink: #0c0d12;
    --vs-ink-soft: #14151c;
    --vs-bone: #e9e3d3;
    --vs-bone-dim: rgba(233, 227, 211, 0.62);
    --vs-bone-faint: rgba(233, 227, 211, 0.28);
    --vs-rule: rgba(233, 227, 211, 0.14);
    --vs-accent: #b8a6d1;
    --vs-serif: "IBM Plex Serif", "Source Serif 4", "EB Garamond", Georgia,
      "Times New Roman", serif;
    --vs-ease: cubic-bezier(0.2, 0.65, 0.25, 1);

    background: var(--vs-ink);
    color: var(--vs-bone);
    font-family: var(--vs-serif);
    font-weight: 400;
    font-size: 16px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    /* Hung punctuation where the browser supports it — small but right. */
    hanging-punctuation: first last;
  }

  .vs ::selection {
    background: var(--vs-accent);
    color: var(--vs-ink);
  }

  .vs a {
    color: inherit;
    text-decoration: none;
    transition: color 380ms var(--vs-ease);
  }

  .vs a:hover {
    color: var(--vs-accent);
  }

  .vs h1,
  .vs h2,
  .vs h3 {
    font-family: var(--vs-serif);
    font-weight: 400;
    margin: 0;
  }

  .vs :focus-visible {
    outline: 1px solid var(--vs-accent);
    outline-offset: 6px;
  }

  /* Single column — the verse is the spine. Generous side margin so the long
     lines breathe and the eye stays in one channel. */
  .vs-shell {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 0 clamp(20px, 6vw, 56px);
  }

  /* A "line of the verse" used as a section header. Same scale & leading as
     the hero lines so the page reads as one continuous lyric. */
  .vs-line {
    font-family: var(--vs-serif);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(34px, 7vw, 64px);
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--vs-bone);
    text-wrap: balance;
    margin: 0;
  }

  /* Small caps tag set inside the lyric for stage directions / labels. */
  .vs-tag {
    font-family: var(--vs-serif);
    font-weight: 500;
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--vs-bone-faint);
  }

  /* Soft entrance: each block fades up once it enters view. Tiny delay
     cascade is set on individual blocks with inline --d. */
  .vs-rise {
    opacity: 0;
    transform: translateY(8px);
    animation: vs-rise 900ms var(--vs-ease) forwards;
    animation-delay: var(--d, 0ms);
  }

  @keyframes vs-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vs,
    .vs *,
    .vs *::before,
    .vs *::after {
      transition-duration: 0.001ms !important;
      animation-duration: 0.001ms !important;
      animation-delay: 0ms !important;
    }
    .vs-rise {
      opacity: 1;
      transform: none;
    }
  }
</style>
